function TsrvFileManageRestService.CheckFileExists(const AAppID: Integer;
  const AFilePath, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if AAppID=0 then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AFilePath)='' then
  begin
    ADesc:=('文件路径不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  try


    //判断文件是否存在
    if FileExists(FileManageServiceModule.dmFileIndyHttpServer.WWWRootDir+AFilePath) then
    begin

        //成功
        ADesc:=('文件存在');
        ACode:=SUCC;

    end
    else
    begin
        //文件不存在
        ADesc:=('文件不存在');
    end;


  finally
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;


