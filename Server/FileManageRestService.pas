  AServiceList:=GlobalServiceProject.kbmMWServer1.DefinedServiceList.Services.BeginWrite;
  try
    for I := 0 to AServiceList.Count-1 do
    begin
      if TkbmMWHTTPServiceDefinition(AServiceList[I]).ServiceClass.ClassName='TsrvFileManageRestService' then
      begin
          //如果图片不存在,则在AWWWRootDir这个目录中找

          //mwhuroCheckFileExists,存在这个文件就用这个路径,如果不存在,则不替换链接
          //http://127.0.0.1:10050/filemanage/20141208-00013.jpg
