          {$IFDEF MSWINDOWS}
          TkbmMWHTTPServiceDefinition(AServiceList[I]).Rewrites.Add('/filemanage/',AWWWRootDir,[mwhuroCheckFileExists]);
          {$ENDIF}

      end;
    end;
  finally
    GlobalServiceProject.kbmMWServer1.DefinedServiceList.Services.EndWrite;
  end;

end;

