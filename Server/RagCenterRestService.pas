//                                    ACode,
//                                    ADesc,
//                                    ADataJson,
//                                    nil
//                                    ) then
//      begin
//        Exit;
//      end;
      //查询记录
      if not AIntfItem.GetRecord(AIntfItem.DBModule,nil,
                                    '',
                                    AWhereKeyJsonArray.AsJSON,
