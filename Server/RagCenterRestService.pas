                                    '',
                                    '',0,0,'',0,
                                    ACode,
                                    ADesc,
                                    ADataJson,
                                    nil
                                    ) then
      begin
        Exit;
      end;


      //http://127.0.0.1:10022/ragcenter/ai/model/list
