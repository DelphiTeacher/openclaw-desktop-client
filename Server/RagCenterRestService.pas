                                    MaxInt,
                                    AWhereKeyJsonArray.AsJSON,
                                    '',
                                    '',0,0,'',0,
                                    ACode,
                                    ADesc,
                                    ADataJson,
                                    nil
                                    ) then
      begin
        Exit;
      end;



  finally

      Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;

  end;

