    ADataJson:=JSonFromRecord(ASQLDBHelper.Query);
    JSonFromDataSetTo(ASQLDBHelper.Query,'User',ADataJson);
    //登录Token随机字符串
    //和登录Key一样
    ADataJson.S['Key']:=AKey;//CreateGUIDString;//'123456';
    ADataJson.A['User'].O[0].S['Key']:=AKey;//CreateGUIDString;//'123456';


    //是否需要ChatGPT的使用情况
    if is_need_chatgpt_use_status='1' then
    begin


      //[今日/总计]：
      //消耗tokens	today_tokens		total_tokens
      //3.5使用次数	today_chat_count		total_chat_count
      //4.0使用次数	today_advanced_chat_count	total_advanced_chat_count
      //绘图次数		today_draw_count		total_draw_count
      //
      //[每日免费额度]：
      //tokens		free_tokens
      //3.5次数		free_chat_count
      //4.0次数		free_advanced_chat_count
      //绘图次数		freer_draw_count
      //
      //[套餐量]：
      //tokens数		limit_tokens
      //3.5次数		limit_chat_count
      //4.0次数		limit_advanced_chat_count
      //绘图次数		limit_draw_count

      //ADataJson.O['chatgpt_3_5_use_status']:=UserCenterServiceModule.do_get_user_chat_gpt_3_5_status(AUserAccessToken.AppID,AUserAccessToken.UserFID);

      AUserOrderGoodsUseStatus:=GlobalUserOrderGoodsUseStatusList.GetStatus(AUserAccessToken.AppID,AUserAccessToken.UserFID,'GPT3.5 月卡');

      AUserOrderGoodsUseStatus.CheckNewDay;
      //3.5使用次数
      ADataJson.I['today_chat_count']:=AUserOrderGoodsUseStatus.TodayUsedServiceCount;
      ADataJson.I['total_chat_count']:=AUserOrderGoodsUseStatus.SumServiceCount;
      //今日剩余的每日免费额度
      ADataJson.I['free_chat_count']:=AUserOrderGoodsUseStatus.SumTrialServiceCountPerDay-AUserOrderGoodsUseStatus.TodayUsedTrialServiceCount;
      //每日免费额度
      ADataJson.I['total_free_chat_count']:=AUserOrderGoodsUseStatus.SumTrialServiceCountPerDay;
      //剩余的套餐量
      ADataJson.I['limit_chat_count']:=AUserOrderGoodsUseStatus.SumServiceCount-AUserOrderGoodsUseStatus.SumUsedServiceCount;
      //套餐过期时间
      ADataJson.S['expiresTime']:=AUserOrderGoodsUseStatus.expiresTime;



    end;


    ADesc:=('获取成功');
    ACode:=SUCC;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;
end;

function TsrvUserCenterRestService.BindPhoneNum(const AAppID:String;const  AUserFID: String;
  const AKey :String; const AUserType :Integer; const APhone, ACaptcha, APassword, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc,APhoneBack:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
var
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不存在');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APhone)='' then
  begin
    ADesc:=('手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(APhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

      //判断账户是否存在
      if not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
      begin
        Exit;
      end;


      APhoneBack:=ASQLDBHelper.Query.FieldByName('phone').AsString;

      //判断要该用户是否已经绑定手机号码
      if Trim(APhoneBack)<>'' then
      begin
        ADesc:=('该账户已绑定手机号码，不能重复绑定');
        Exit;
      end;




      //判断该手机号码是否已经被同类型其他用户绑定
      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                            +' WHERE appid=:appid '
                            +' and user_type=:user_type'
                            +' and phone=:phone' ,
                            ['appid','user_type','phone'],
                            [AAppID,AUserType,APhone],
                            asoOpen) then
      begin
        ASQLDBHelper.Query.First;
        if Not ASQLDBHelper.Query.Eof then
        begin
          //存在此用户
          ADesc:=('该手机号码已经被注册或绑定');
          Exit;
        end;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      end;


      //用接口比对验证码
      AHttpResponse:=SimpleCallAPI(GlobalServiceProject.CaptchaServer+'check_captcha',
                                  nil,
                                  '',
                                  ['appid',
                                  'user_type',
                                  'account',
                                  'captcha_type',
                                  'captcha'],
                                  [AAppID,
                                  AUserType,
                                  APhone,
                                  Const_CaptchaType_BindPhoneNum,
                                  ACaptcha],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                                  );
      AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

      if AHttpResponseJson.I['Code']<>SUCC then
      begin
        //数据库连接失败或异常
        ADesc:=('验证码不正确');
        Exit;
      end;


      // 判断是否需要更新密码
      if APassword <> '' then
      begin

        //绑定手机
        if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                  +' SET phone=:phone, password=:password '
                                  +' WHERE appid=:appid and fid=:fid ',
                                  ['appid','fid','phone','password'],
                                  [AAppID,AUserFID,APhone,Apassword],
                                  asoExec) then
        begin
          //绑定成功
          ADesc:=('绑定成功');
          ACode:=SUCC;

          //查询用户
          if QueryUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
          begin
            ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');
          end;

        end
        else
        begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        end;

      end
      else
      begin

        //绑定手机
        if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                  +' SET phone=:phone '
                                  +' WHERE appid=:appid and fid=:fid ',
                                  ['appid','fid','phone'],
                                  [AAppID,AUserFID,APhone],
                                  asoExec) then
        begin
          //绑定成功
          ADesc:=('绑定成功');
          ACode:=SUCC;

          //查询用户
          if QueryUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
          begin
            ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');
          end;

        end
        else
        begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        end;

      end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.BindThirdpartyAccount(const AAppID:String;const
  AUserFID: String;
  const AKey:String;
//  const AUserType:Integer;
  const AWxUnionId,AWxOpenID, AWxAuthToken,
  AAlipayOpenID, AAlipayAuthToken,
  AFbOpenID,AFbAuthToken,
  ATwOpenID, ATwAuthToken,
  AAppleOpenID, AAppleAuthToken,

  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
  AUserType:Integer;
//var
//  AHttpResponse,ABindType:String;
//  AHttpResponseJson:ISuperObject;
var
  ABindType:String;
  AWxUnionIdBack,AWxOpenIDBack,AAlipayOpenIDBack,AFbOpenIDBack,ATwOpenIDBack:String;

  AAppleOpenIDBack:String;
  ABindSql:String;
  ABindKey: TStringDynArray;
  ABindValue: TVariantDynArray;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不存在');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try



    //判断账户是否存在
    if IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      AUserType:=ASQLDBHelper.Query.FieldByName('user_type').AsInteger;

      AWxUnionIDBack:=ASQLDBHelper.Query.FieldByName('wx_union_id').AsString;
      AWxOpenIDBack:=ASQLDBHelper.Query.FieldByName('wx_open_id').AsString;

      AAlipayOpenIDBack:=ASQLDBHelper.Query.FieldByName('alipay_open_id').AsString;

      AAppleOpenIDBack:=ASQLDBHelper.Query.FieldByName('apple_open_id').AsString;

      AFbOpenIDBack:=ASQLDBHelper.Query.FieldByName('fb_open_id').AsString;

      ATwOpenIDBack:=ASQLDBHelper.Query.FieldByName('tw_open_id').AsString;



      //去掉,可以覆盖绑定
//      //判断要绑定第三方账号的类型并验证是否已经绑定
//      if (Trim(AWxOpenID)<>'') and (Trim(AWxOpenIDBack)<>'') then
//      begin
//        ADesc:=('该账户已绑定微信，不能重复绑定');
//        Exit;
//      end;
//      if (Trim(AAlipayOpenID)<>'') and (Trim(AAlipayOpenIDBack)<>'') then
//      begin
//        ADesc:=('该账户已绑定支付宝，不能重复绑定');
//        Exit;
//      end;
//      if (Trim(AAppleOpenID)<>'') and (Trim(AAppleOpenIDBack)<>'') then
//      begin
//        ADesc:=('该账户已绑定Apple，不能重复绑定');
//        Exit;
//      end;
//
//      if (Trim(AFbOpenID)<>'') and (Trim(AFbOpenIDBack)<>'') then
//      begin
//        ADesc:=('该账户已绑定FaceBook，不能重复绑定');
//        Exit;
//      end;
//
//      if (Trim(ATwOpenID)<>'') and (Trim(ATwOpenIDBack)<>'') then
//      begin
//        ADesc:=('该账户已绑定Twitter，不能重复绑定');
//        Exit;
//      end;




      //判断该第三方账号是否已经被其他用户绑定
      if Trim(AWxOpenID)<>'' then
      begin
        //条件
        ABindType:=' and (wx_open_id= '+QuotedStr(AWxOpenID) + ' '
                      +' OR ( wx_union_id<>'''' and wx_union_id= '+QuotedStr(AWxUnionID) + ' ) '
                      +' ) ';

        ABindSql:=' SET wx_union_id=:wx_union_id,wx_open_id=:wx_open_id,wx_auth_token=:wx_auth_token ';

        ABindKey:=['appid','fid','wx_union_id','wx_open_id','wx_auth_token'];
        ABindValue:=[AAppID,AUserFID,AWxUnionID,AWxOpenID,AWxAuthToken];
      end
      else if Trim(AAlipayOpenID)<>'' then
      begin
        ABindType:=' and alipay_open_id= '+QuotedStr(AAlipayOpenID) + ' ';

        ABindSql:=' SET alipay_open_id=:alipay_open_id,alipay_auth_token=:alipay_auth_token ';

        ABindKey:=['appid','fid','alipay_open_id','alipay_auth_token'];
        ABindValue:=[AAppID,AUserFID,AAlipayOpenID,AAlipayAuthToken];
      end
      else if Trim(AAppleOpenID)<>'' then
      begin
        ABindType:=' and apple_open_id= '+QuotedStr(AAppleOpenID) + ' ';

        ABindSql:=' SET apple_open_id=:apple_open_id,apple_auth_token=:apple_auth_token ';

        ABindKey:=['appid','fid','apple_open_id','apple_auth_token'];
        ABindValue:=[AAppID,AUserFID,AAppleOpenID,AAppleAuthToken];
      end
      else if Trim(AFbOpenID)<>'' then
      begin
        ABindType:=' and fb_open_id= '+QuotedStr(AFbOpenID) + ' ';

        ABindSql:=' SET fb_open_id=:fb_open_id,fb_auth_token=:fb_auth_token ';

        ABindKey:=['appid','fid','fb_open_id','fb_auth_token'];
        ABindValue:=[AAppID,AUserFID,AFbOpenID,AFbAuthToken];
      end
      else if Trim(ATwOpenID)<>'' then
      begin
        ABindType:=' and tw_open_id= '+QuotedStr(ATwOpenID) + ' ';

        ABindSql:=' SET tw_open_id=:tw_open_id,tw_auth_token=:tw_auth_token ';

        ABindKey:=['appid','fid','tw_open_id','tw_auth_token'];
        ABindValue:=[AAppID,AUserFID,ATwOpenID,ATwAuthToken];
      end;

      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                                +' WHERE appid=:appid '
                                + ABindType
                                +' and user_type=:user_type ',
                                ['appid','user_type'],
                                [AAppID,AUserType],
                                asoOpen) then
      begin
        ASQLDBHelper.Query.First;
        if Not ASQLDBHelper.Query.Eof then
        begin
          //存在此用户
          ADesc:=('该三方账号已经被注册或绑定');
          Exit;
        end;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      end;


      //绑定第三方账户
      if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                +ABindSql
                                +' WHERE appid=:appid and fid=:fid ',
                                ABindKey,
                                ABindValue,
                                asoExec) then
      begin
        //绑定成功
        ADesc:=('绑定成功');
        ACode:=SUCC;

        //查询用户
        if QueryUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
        begin
          ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');
        end;

      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      end;

    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.ChangePassword(const AAppID:String;const AUserType: Integer; const AUserFID:String;
  const AKey, AOldPassword, APassword, ARePassword, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //原密码可能为空的,门业项目
//  if Trim(AOldPassword)='' then
//  begin
//    ADesc:=('原密码不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  if Trim(APassword)='' then
  begin
    ADesc:=('密码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ARePassword)='' then
  begin
    ADesc:=('密码确认不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if APassword<>ARePassword then
  begin
    ADesc:=('两次输入的密码不相同');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and fid=:fid',
                              ['appid','user_type','fid'],
                              [AAppID,AUserType,AUserFID],
                              asoOpen) then
    begin
      ASQLDBHelper.Query.First;
      if Not ASQLDBHelper.Query.Eof then
      begin
          //存在此用户

          //比对密码
          if ASQLDBHelper.Query.FieldByName('password').AsString=AOldPassword then
          begin

                //密码修改
                if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                          +' SET password=:password '
                                          +' WHERE appid=:appid and fid=:fid '
                                          +' and user_type=:user_type',
                                          ['appid','password','fid','user_type'],
                                          [AAppID,APassword,AUserFID,AUserType],
                                          asoExec) then
                begin
                  //密码修改成功
                  ADesc:=('密码修改成功');
                  ACode:=SUCC;
                end
                else
                begin
                  //数据库连接失败或异常
                  ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
                end;

          end
          else
          begin
                ADesc:=('原密码错误');
          end;

      end
      else
      begin
        //不存在此用户
        ADesc:=('不存在此用户');
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

