function TsrvUserCenterRestService.GetKeepSignInDays(const AAppID: String;
  const AUserFID, AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:='AppID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:='UserFID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  try
    //获取用户连续签到天数  当天是否签到会影响返回结果
    if not ASQLDBHelper.SelfQuery('SELECT count(1) days FROM ( '
                                  +' SELECT date_sub(a.createtime,INTERVAL 1 DAY) signDate,'
                                  +' (@i:=DATE_ADD(@i,INTERVAL-1 DAY)) today FROM ( '
                                  +' SELECT createtime FROM shop_center.tbluser_signed_shop WHERE user_fid=:fid and appid=:appid ORDER BY createtime DESC) a INNER JOIN ( '
                                  +' SELECT @i:=max(createtime) AS signMax FROM shop_center.tbluser_signed_shop WHERE user_fid=:fid and appid=:appid '
                                  +' AND (TO_DAYS(createtime)=TO_DAYS(curdate()) OR TO_DAYS(createtime)=TO_DAYS(DATE_ADD(curdate(),INTERVAL-1 DAY)))) b '
                                  +' WHERE b.signMax IS NOT NULL AND TO_DAYS(DATE_ADD(@i,INTERVAL-1 DAY))=TO_DAYS(date_sub(a.createtime,INTERVAL 1 DAY))) c ',
                                  ['appid','fid'],
                                  [AAppID,AUserFID],
                                  asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    if ASQLDBHelper.Query.Eof then
    begin
      ADesc:=('用户不存在');
      Exit;
    end;

    ADataJson:=TSuperObject.Create;
    ADataJson.I['Days']:=ASQLDBHelper.Query.FieldByName('Days').AsInteger;
    //查询当天是否签到
    if ASQLDBHelper.SelfQuery('SELECT COUNT(*) CNT FROM shop_center.tbluser_signed_shop '
                                +' WHERE appid=:appid and IFNULL(is_deleted,0)=0 '
                                +' AND user_fid=:user_fid and createtime>=CURDATE() ',
                                ['appid','user_fid'],
                                [AAppID,AUserFID],
                                asoOpen) then
    begin
      ADataJson.I['IsSigned']:=0; // 0 未签到  1 已签到
      if ASQLDBHelper.Query.FieldByName('CNT').AsInteger>0 then ADataJson.I['IsSigned']:=1;
      ACode:=SUCC;
      ADesc:=('获取用户连续签到天数及是否签到成功');
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;
end;

function TsrvUserCenterRestService.GetLoginHistoryList(const AAppID:String;const  AEmpFID: String;
  const AUserFID: String;const AKey:String;const APageIndex,APageSize:Integer;const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc,AFilterUserFID:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AEmpFID)='') or (Trim(AEmpFID)='0') then
  begin
    ADesc:=('EmpFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  AFilterUserFID:='';
  if Trim(AUserFID)<>'' then
  begin
    AFilterUserFID:=' and user_fid='+ AUserFID +'';
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    //检查是否是合法的员工
    if Not IsValidUser(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
    begin

      Exit;
    end;



    //查询登陆历史列表
    if ASQLDBHelper.SelfQuery(' SELECT A.*,B.name from tbluser_login_history A'
                              +' LEFT JOIN tbluser B on A.appid=B.appid and A.user_fid=B.fid'
                              +' WHERE A.appid=:appid '
                              + AFilterUserFID
                              +' ORDER BY A.login_time DESC '
                              +' LIMIT :pageindex,:pagesize ',
                              ['appid',
                              'pageindex',
                              'pagesize'],
                              [
                              AAppID,
                              (APageIndex-1)*APageSize,
                              APageSize
                              ],
                              asoOpen) then
    begin
      //成功
      ADesc:=('查询登录历史列表成功');
      ACode:=SUCC;
      ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'LoginHistoryList');

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;
