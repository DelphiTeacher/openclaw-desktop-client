function TsrvUserCenterRestService.AddUserRecvAddr(const AAppID:String;const
  AUserFID: String; const AKey, AName, APhone, ACountry, AProvince, ACity,
  AArea, AAddr,AStreet,ABuilding,AAddrLine3,APostcode,
  ATag: String; const ALatitude, ALongitude: Double;
  const AIsDefault, ASex: Integer; const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;

  AUserRecvAddrFID:Integer;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AName)='' then
  begin
    ADesc:=('姓名不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APhone)='' then
  begin
    ADesc:=('手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(APhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


//  if Trim(AProvince)='' then
//  begin
//    ADesc:=('省不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;
//
//  if Trim(ACity)='' then
//  begin
//    ADesc:=('市不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;
//
//  if (ALatitude=0) OR (ALongitude=0) then
//  begin
//    ADesc:=('经纬度不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  if Trim(AAddr)='' then
  begin
    ADesc:=('地址不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AStreet)='' then
  begin
    ADesc:=('街道地址不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  {$IFDEF NZ}
  if Trim(APostcode)='' then
  begin
    ADesc:=('邮编不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  {$ENDIF}

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin

      Exit;
    end;

    //添加收货地址
    if ASQLDBHelper.SelfQuery('INSERT INTO tbluser_recv_addr'
                            +' (appid,user_fid,name,sex,phone,country,province,city,area, '
                            +' addr,street,building,addr_line3,postcode,latitude,longitude,is_default,tag,createtime) '
                            +' VALUES '
                            +' (:appid,:user_fid,:name,:sex,:phone,:country,:province,:city,:area, '
                            +' :addr,:street,:building,:addr_line3,:postcode,:latitude,:longitude,:is_default,:tag,:createtime); '
                            +' SELECT last_insert_id() as fid; ',
                            ['appid','user_fid','name','sex','phone','country','province','city','area',
                            'addr','street','building','addr_line3','postcode', 'latitude', 'longitude','is_default','tag','createtime'],
                            [
                            AAppID,
                            AUserFID,
                            AName,
                            ASex,
                            APhone,
                            ACountry,
                            AProvince,
                            ACity,
                            AArea,
                            AAddr,
                            AStreet,ABuilding,AAddrLine3,APostcode,
                            ALatitude,
                            ALongitude,
                            AIsDefault,
                            ATag,
                            Now
                            ],
                            asoOpen) then
    begin

        AUserRecvAddrFID:=ASQLDBHelper.Query.FieldByName('fid').AsInteger;

        if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_recv_addr '
                                  +' WHERE appid=:appid '
                                  +' and fid=:fid ',
                                  ['appid','fid'],
                                  [AAppID,
                                  AUserRecvAddrFID
                                  ],
                                  asoOpen) then
        begin

            //成功
            ADesc:=('用户收货地址添加成功');
            ACode:=SUCC;

            ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'UserRecvAddr');

            //设置默认收货地址
            if AIsDefault=1 then
            begin
              SetUserRecvAddrIsDefault(AAppID,AUserFID,AKey,AUserRecvAddrFID,ARemoteLocation);
            end;

        end
        else
        begin
            //数据库连接失败或异常
            ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;

        end;


    end
    else
    begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;

    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

function TsrvUserCenterRestService.AnonymousGetUserPublicInfo(const AAppID:String;const
