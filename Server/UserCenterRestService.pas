function TsrvUserCenterRestService.GetInviteCodeInfo(const AAppID: String;
  const ARequesterPhone, ARequesterName, AInviteCode,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //请求人的手机号和姓名不一定需要
  //因为注册一开始就要输入邀请码,这时候并没有输入注册人的姓名和手机号

//  if Trim(ARequesterPhone)='' then
//  begin
//    ADesc:=('请求人手机号不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;
//
//  if Not IsMobPhone(ARequesterPhone) then
//  begin
//    ADesc:=('请求人手机号格式不正确');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;
//
//  if Trim(ARequesterName)='' then
//  begin
//    ADesc:=('请求人姓名不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;



  if Trim(AInviteCode)='' then
  begin
    ADesc:=('邀请码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    //查询邀请码信息
    if QueryInviteCodeInfo(ASQLDBHelper,
                          AAppID,
                          AInviteCode,
                          ADesc) then
    begin

      //邀请码不能超时,以秒计算
      if (DateUtils.SecondsBetween(ASQLDBHelper.Query.FieldByName('createtime').AsDateTime,Now)
          >ASQLDBHelper.Query.FieldByName('timeout').AsInteger) then
      begin
        ADesc:=('此邀请码已过期');
        Exit;
      end;


//      //邀请码是否使用过
//      if Not VarIsNull(ASQLDBHelper.Query.FieldByName('is_used').Value)
//        and (ASQLDBHelper.Query.FieldByName('is_used').AsInteger=1) then
//      begin
//        ADesc:=('此邀请码已经被使用';
//        Exit;
//      end;

      //返回邀请码的信息
      ADataJson:=TSuperObject.Create;
      JSonFromDataSetTo(ASQLDBHelper.Query,'InviteCodeInfo',ADataJson);

      //用户是否合法
      //获取邀请码对应的介绍人的用户信息

      if Not IsValidUser(ASQLDBHelper,
                            AAppID,
                            ASQLDBHelper.Query.FieldByName('user_fid').AsString,
                            ADesc) then
      begin
          //邀请码对应的用户不存在
          ADesc:=('邀请码对应的用户不存在'+' '+ADesc);
          Exit;
      end;



      //成功
      ADesc:=('查询邀请码成功');
      ACode:=SUCC;

      JSonFromDataSetTo(ASQLDBHelper.Query,'User',ADataJson);

    end
    else
    begin
        //获取邀请码失败
        ADesc:=('获取邀请码失败'+' '+ADesc);
    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.getInviterPhone(const AAppID:String;const
  AInviterUserFID: String; const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (AInviterUserFID='') or (AInviterUserFID='0') then
  begin
    ADesc:=('InviterFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    if ASQLDBHelper.SelfQuery('SELECT phone,name FROM tbluser '
                            +' WHERE appid=:appid '
                            +' and fid=:fid',
                            ['appid','fid'],
                            [AAppID,AInviterUserFID],
                            asoOpen) then
    begin

      if Not ASQLDBHelper.Query.Eof then
      begin
        //成功
        ADesc:=('查询用户手机号码成功');
        ACode:=SUCC;
        ADataJson:=TSuperObject.Create();
        ADataJson.S['phone']:=ASQLDBHelper.Query.FieldByName('phone').AsString;
      end
      else
      begin
        //用户不存在
        ADesc:=('用户不存在');
        Exit;
      end;

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

