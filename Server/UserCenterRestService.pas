  Result:=False;

  //不同的计算方式，有些是计数的,有些是按照有效期的

  if Self.ShopGoodsName='GPT3.5 月卡' then
  begin

    CheckNewDay;

    //如果有每天的免费使用次数,看看有没有超
    if SumTrialServiceCountPerDay>0 then
    begin
      if TodayUsedTrialServiceCount<SumTrialServiceCountPerDay then
      begin
        Result:=True;
        Exit;
      end;
    end;

    Result:=Self.SumServiceCount>Self.SumUsedServiceCount;

    if not Result then
    begin
      ADesc:='服务次数已用完';
    end;

  end
  else
  begin
    //只判断是否过期
    Result:=(expiresTime='') or (expiresTime<>'') and (StdDateToStr(Now)<Self.expiresTime);
    if not Result then
    begin
      ADesc:='授权已过期';
    end;

  end;


