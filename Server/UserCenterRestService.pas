function TsrvUserCenterRestService.IsUserNameExist(const AAppID: String;
  const AKey:String;
  const AUserType:Integer;
  const AUserName, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if AUserName='' then
  begin
    ADesc:=('UserName不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    if not ASQLDBHelper.SelfQuery(
              'SELECT * FROM tbluser '
              +' WHERE appid=:appid '
              +' and user_type=:user_type '
              +' and name=:name',
              ['appid','user_type','name'],
              [AAppID,AUserType,AUserName],
              asoOpen) then
    begin
      ADesc:=ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    ACode:=SUCC;
    ADataJson:=TSuperObject.Create();
    ADataJson.B['is_exist']:=not ASQLDBHelper.Query.Eof;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

