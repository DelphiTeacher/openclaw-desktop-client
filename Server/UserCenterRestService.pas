function TsrvUserCenterRestService.ChangeUserBankcard(const AAppID:String;const
  AUserFID: String; const AKey: String; const ABankcardFID: Integer;
  const ABankcardAccount, ABankcardName, ABankcardType:String;
  const AIsDefault:Integer;const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //为0时 表示平台银行卡信息
  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if ABankcardFID=0 then
  begin
    ADesc:=('BankcardFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardAccount)='' then
  begin
    ADesc:=('BankcardAccount不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardName)='' then
  begin
    ADesc:=('BankcardName不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardType)='' then
  begin
    ADesc:=('BankcardType不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (AIsDefault<>0) and (AIsDefault<>1) then
  begin
    ADesc:=('IsDefault不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    if (Trim(AUserFID)<>'') and (Trim(AUserFID)<>'0') then
    begin
      if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
      begin
        ADesc:=('用户不合法');
        Exit;
      end;
    end;

    //修改用户银行卡信息
    if ASQLDBHelper.SelfQuery('UPDATE tbluser_bankcard_info '
                            +' SET bankcard_account=:bankcard_account, '
                            +' bankcard_name=:bankcard_name, '
                            +' bankcard_type=:bankcard_type, '
                            +' is_default=:is_default '
                            +' WHERE appid=:appid '
                            +' and fid=:fid ',
                            ['bankcard_account','bankcard_name','bankcard_type',
                            'is_default',
                            'appid',
                            'fid'],
                            [ABankcardAccount, ABankcardName, ABankcardType,
                            AIsDefault,
                            AAppID,
                            ABankcardFID
                            ],
                            asoExec) then
    begin
      //成功
      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_bankcard_info '
                              +' WHERE appid=:appid '
                              +' and fid=:fid',
                              ['appid',
                              'fid'],
                              [AAppID,
                              ABankcardFID],
                              asoOpen) then
      begin
        if Not ASQLDBHelper.Query.Eof then
        begin
          ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'UserBankcardInfo');
          ACode:=SUCC;
          ADesc:=('修改用户银行卡信息成功');
        end
        else
        begin
          ADesc:=('记录不存在');
          Exit;
        end;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

