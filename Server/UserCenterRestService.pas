function TUserCenterServiceModule.AnonymousGetUserPublicInfo(
  ASQLDBHelper: TBaseDBHelper; const AAppID: String; const AGetUserFID: String;
  var ADesc: String; var ADataJson: ISuperObject): Boolean;
begin

    Result:=False;

    //查询用户
    if not ASQLDBHelper.SelfQuery(
            'SELECT fid,appid,user_type,name,age,sex,score,head_pic_path,province,city,'
              //加入FastmsgUserID,显示用户信息的时候使用
              +'fastmsg_user_id '
            +' FROM '+UserCenterServiceModule.DBModule.DBConfig.GetTablePrefix+'tbluser '
            +' WHERE appid=:appid '
            +' and fid=:fid '
            +' and IFNULL(is_deleted,0)=0 ',
            ['appid','fid'],
            [AAppID,AGetUserFID],asoOpen) then
    begin
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


    if not ASQLDBHelper.Query.Eof then
    begin
      //存在用户
      ADataJson:=JSonFromRecord(ASQLDBHelper.Query);
    end
    else
    begin
      //不存在用户也不能提示失败
    end;

    Result:=True;

end;

