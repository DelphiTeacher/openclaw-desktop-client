function TsrvUserCenterRestService.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var
  ADesc:String;
  AStartTime:TDateTime;
begin
  AStartTime:=Now;


  ProcessCORSRequest;

  if (length(Args)>2)
    and (ClientIdent.ServicePath<>'/usercenter/helloworld')
    and (ClientIdent.ServicePath<>'/usercenter/echostring')


    and (ClientIdent.ServicePath<>'/usercenter/login_post')
    and (ClientIdent.ServicePath<>'/usercenter/login')
    and (ClientIdent.ServicePath<>'/usercenter/loginout_by_header_key')
    and (ClientIdent.ServicePath<>'/usercenter/loginout')
    and (ClientIdent.ServicePath<>'/usercenter/send_login_captcha')
    and (ClientIdent.ServicePath<>'/usercenter/auto_login')
    and (ClientIdent.ServicePath<>'/usercenter/register_user')
    and (ClientIdent.ServicePath<>'/usercenter/send_register_captcha')
    and (ClientIdent.ServicePath<>'/usercenter/check_register_captcha')
    and (ClientIdent.ServicePath<>'/usercenter/send_forget_password_captcha')
    and (ClientIdent.ServicePath<>'/usercenter/check_forget_password_captcha')
    and (ClientIdent.ServicePath<>'/usercenter/reset_forget_password')
    and (ClientIdent.ServicePath<>'/usercenter/change_password')
    and (ClientIdent.ServicePath<>'/usercenter/is_third_party_account_exist')


    and (ClientIdent.ServicePath<>'/usercenter/check_app_version')
    and (ClientIdent.ServicePath<>'/usercenter/get_app_upgrade_files')

    then
  begin
//    uBaseLog.HandleException(nil,'TsrvUserCenterRestService.ProcessRequest Args[0]:'+Args[0]);
//    uBaseLog.HandleException(nil,'TsrvUserCenterRestService.ProcessRequest Args[1]:'+Args[1]);
//    uBaseLog.HandleException(nil,'TsrvUserCenterRestService.ProcessRequest Args[2]:'+Args[2]);
//    uBaseLog.HandleException(nil,'TsrvUserCenterRestService.ProcessRequest ClientIdent.ServicePath:'+ClientIdent.ServicePath);

    //验签
    //取到appid,获取到appsecret,再验签,appid放在列表中,每次服务器启动时获取签名
    if not GlobalServiceProject.CheckInterfaceSign(ClientIdent,RequestTransportStream,ClientIdent.ServicePath,Args[2],ADesc) then
    begin
      Result:=ReturnJson(FAIL,ADesc,nil).AsJSON;
      Exit;
    end;

  end;


  Result:=Inherited;


  //统计接口调用
  GlobalServiceProject.FAPICallStatisticsList.AddCall(ClientIdent.ServicePath,DateUtils.MilliSecondsBetween(Now,AStartTime));


end;

