    //4.0次数		free_advanced_chat_count
    //绘图次数		freer_draw_count
    //
    //[套餐量]：
    //tokens数		limit_tokens
    //3.5次数		limit_chat_count
    //4.0次数		limit_advanced_chat_count
    //绘图次数		limit_draw_count

    //ADataJson.O['chatgpt_3_5_use_status']:=UserCenterServiceModule.do_get_user_chat_gpt_3_5_status(AUserAccessToken.AppID,AUserAccessToken.UserFID);

    AUserOrderGoodsUseStatus:=GlobalUserOrderGoodsUseStatusList.GetStatus(AUserAccessToken.AppID,AUserAccessToken.UserFID,'GPT3.5 月卡');
    //手动再刷新一下
    AUserOrderGoodsUseStatus.LoadLicense;


    ADesc:=('刷新成功');
    ACode:=SUCC;


  finally
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

