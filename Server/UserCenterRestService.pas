function TsrvUserCenterRestService.NoticeUser(const AAppID:String;const  AUserFID: String;
  const AKey: String; const ASenderFID,recver_fid: String; const ANoticeCalssify,
  ANoticeSubType, ACaption, AContent, ACustomDataJson, is_need_push, is_need_sms,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
  ARecvUserFID:String;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if recver_fid<>'' then
  begin
    ARecvUserFID:=recver_fid;
  end
  else
  begin
    ARecvUserFID:=AUserFID;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try



    //给用户发送通知
    if not DoNoticeUser(ASQLDBHelper,
                        AAppID,
                        AUserFID,
                        AKey,
                        ARecvUserFID,
                        ASenderFID,
                        ANoticeCalssify,
                        ANoticeSubType,
                        ACaption,
                        AContent,
                        AContent,
                        ACustomDataJson,
                        (is_need_push<>'0'),
                        (is_need_sms='1'),
                        ADesc) then
    begin

      Exit;
    end;

    //成功
    ADesc:=('通知用户成功');
    ACode:=SUCC;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

