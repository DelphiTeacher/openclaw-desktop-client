  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try




    //判断用户是否合法
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin

      Exit;
    end;

    //获取通知是否已读
    if ASQLDBHelper.SelfQuery('DELETE FROM tbluser_notice_read_state '
                              +' WHERE appid=:appid '
                              +' and user_fid=:user_fid '
                              +' and notice_fid=:notice_fid ',
                              ['appid',
                              'user_fid',
                              'notice_fid'],
                              [
                              AAppID,
                              AUserFID,
                              ANoticeFID
                              ],
                              asoExec) then
    begin
      if ASQLDBHelper.Query.Eof then
      begin
        //不存在通知阅读记录,那么此通知未读

        //设置通知为已读
        if ASQLDBHelper.SelfQuery('INSERT INTO tbluser_notice_read_state '
                                  +' (appid,user_fid,notice_fid,is_readed,createtime) '
                                  +' VALUES '
                                  +' (:appid,:user_fid,:notice_fid,:is_readed,:createtime) ',
                                  ['appid',
                                  'user_fid',
                                  'notice_fid',
                                  'is_readed',
                                  'createtime'],
                                  [
                                  AAppID,
                                  AUserFID,
                                  ANoticeFID,
                                  1,
                                  Now
                                  ],
                                  asoExec) then
        begin

        end
        else
        begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        end;

      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;

    //查询通知
    if ASQLDBHelper.SelfQuery(Const_QuerySQL_UserNoticeInfo
                              +' WHERE A.appid=:appid '
                              +' and (A.user_fid=:user_fid OR A.user_fid='''') '
                              +' and A.fid=:fid ',
                              ['appid',
                              'user_fid',
                              'fid'
                              ],
                              [
                              AAppID,
                              AUserFID,
                              ANoticeFID
                              ],
                              asoOpen) then
    begin

      //成功
      ADesc:=('查询通知成功');
      ACode:=SUCC;
      ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'Notice');

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

