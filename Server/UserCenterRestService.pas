      if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                +' SET cert_audit_state=:cert_audit_state '
                                +' WHERE appid=:appid '
                                +' and fid=:fid ',
                                ['cert_audit_state',
                                'appid',
                                'fid'],
                                [
                                AAuditState,
                                AAppID,
                                AUserFID
