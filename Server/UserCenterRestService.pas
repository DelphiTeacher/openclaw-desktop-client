function TsrvUserCenterRestService.IsValidEmpRecord(ASQLDBHelper: TBaseDBHelper;
  var ADesc: String): Boolean;
begin
  Result:=False;

  if IsValidUserRecord(ASQLDBHelper,ADesc) then
  begin

    //判断用户是否是员工
    if VarIsNull(ASQLDBHelper.Query.FieldByName('user_type').Value)
      or (ASQLDBHelper.Query.FieldByName('user_type').AsInteger<>3) then
    begin
      ADesc:=('账户不是员工类型');
