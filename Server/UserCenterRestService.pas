function TsrvUserCenterRestService.GetSpreadList(const AAppID: String;
  const AUserFID, AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  ASQLDBHelper:TBaseDBHelper;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:='AppID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:='UserFID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  try
    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then Exit;

    //查询主播固定时间里推广的用户列表
    if ASQLDBHelper.SelfQuery('SELECT NAME,phone,createtime FROM tbluser '
                              +' WHERE appid=:appid '
                              +' AND IFNULL(is_deleted,0)=0 '
                              +' AND bind_introducer_fid=:user_fid '
                              +' AND createtime>=date_sub(NOW(),INTERVAL 1 DAY) ',
                              ['appid','user_fid'],
                              [AAppID,AUserFID],
                              asoOpen) then
    begin
      //成功
      ADesc:='查询推广的用户列表成功';
      ACode:=SUCC;
      ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'SpreadUserList');
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;
end;

function TsrvUserCenterRestService.GetSuggestionlList(const AAppID:String;const
  AEmpFID: String; const AKey: String; const APageIndex, APageSize: Integer;
  const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:='AppID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AEmpFID)='') or (Trim(AEmpFID)='0') then
  begin
    ADesc:='EmpFID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if APageIndex<1 then
  begin
    ADesc:='PageIndex不能小于1';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if APageSize<1 then
  begin
    ADesc:='PageSize不能小于1';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try



    //检查是否是合法的员工
    if Not IsValidEmp(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
    begin

      Exit;
    end;

    //查询意见列表
    if ASQLDBHelper.SelfQuery('SELECT A.*,B.name as user_name '
                              +' FROM tbluser_suggestions A '
                              +' LEFT JOIN tbluser B ON A.appid=B.appid and A.user_fid=B.fid '
                              +' WHERE A.appid=:appid '
//                              +' and IFNULL(is_deleted,0)=0 '
                              +' ORDER BY A.createtime DESC '
                              +' LIMIT :pageindex,:pagesize ',
                              ['appid',
                              'pageindex',
                              'pagesize'],
                              [
                              AAppID,
                              (APageIndex-1)*APageSize,
                              APageSize
                              ],
                              asoOpen) then
    begin


        //成功
        ADesc:='查询意见列表成功';
        ACode:=SUCC;
        ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'UserSuggestionList');

    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

