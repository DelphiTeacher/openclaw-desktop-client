function GetRandStr(len : Integer;
                    lowercase : Boolean = True;
                    num : Boolean = True;
                    uppercase : Boolean = False) : string;
const
  upperStr = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  lowerStr = 'abcdefghijklmnopqrstuvwxyz';
  numStr = '0123456789';
var
  sourceStr : string;
  i : Integer;
begin
  sourceStr := '';
  Result := '';
  if uppercase = True then
    sourceStr := sourceStr + upperStr;
  if lowercase = True then
    sourceStr := sourceStr + lowerStr;
  if num = True then
    sourceStr := sourceStr + numStr;
  if (sourceStr = '') or (len<1) then
    exit;

  Randomize;
  for i:=1 to len do
  begin
    Result := Result + sourceStr[Random(Length(sourceStr)-1)+1];
  end;
end;


//统计商品销售数量
procedure SummaryGoodsSell(ASQLDBHelper:TBaseDBHelper;
                           const AAppId:Integer;
                           const AShopFID:Integer;
                           var ADesc:String);
var
  AGetDataJson:ISuperObject;
  I:Integer;
begin
  //查询每个店铺最近一个月的总订单数 并更新到 对应的字段
  if ASQLDBHelper.SelfQuery('SELECT Count(*) as sum_order FROM shop_center.tblorder '
                      +' WHERE appid=:appid '
                      +' and shop_fid=:shop_fid '
                      +' and order_state=''done'' '
                      +' and createtime>='''+ FormatDateTime('yyyy-mm-dd hh:mm:mm',Now-(1/24/60)*60*24*30)+'''',
                      ['appid',
                      'shop_fid'],
                      [AAppId,
                      AShopFID],
                      asoOpen) then
  begin
    if Not ASQLDBHelper.Query.Eof then
    begin
      //将统计好的数量更新到每个店铺的对应字段中
      if Not ASQLDBHelper.SelfQuery('UPDATE shop_center.tblshop '
                    +' SET recent_order_num=:recent_order_num '
                    +' WHERE appid=:appid '
                    +' and fid=:fid ',
                    ['appid',
                    'fid',
                    'recent_order_num'],
                    [AAppId,
                    AShopFID,
                    ASQLDBHelper.Query.FieldByName('sum_order').AsInteger
                    ],
                    asoExec) then
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end;
  end
  else
  begin
    //数据库连接失败或异常
    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    Exit;
  end;

  //查询每个店铺最近一个月的售出商品总数  并更新到 对应的字段
  if ASQLDBHelper.SelfQuery('SELECT Sum(B.number) as sum_goods FROM shop_center.tblorder A '
                      +' LEFT JOIN shop_center.tblorder_goods B '
                      +' ON A.appid=B.appid and A.fid=B.order_fid '
                      +' WHERE A.appid=:appid '
                      +' and A.shop_fid=:shop_fid '
                      +' and A.order_state=''done'' '
                      +' and A.createtime>='''+ FormatDateTime('yyyy-mm-dd hh:mm:mm',Now-(1/24/60)*60*24*30)+'''',
                      ['appid',
                      'shop_fid'],
                      [AAppId,
                      AShopFID],
                      asoOpen) then
  begin
    if Not ASQLDBHelper.Query.Eof then
    begin
      //将统计好的数量更新到每个店铺的对应字段中
      if Not ASQLDBHelper.SelfQuery('UPDATE shop_center.tblshop '
                    +' SET recent_goods_popularity=:recent_goods_popularity '
                    +' WHERE appid=:appid '
                    +' and fid=:fid ',
                    ['appid',
                    'fid',
                    'recent_goods_popularity'],
                    [AAppId,
                    AShopFID,
                    ASQLDBHelper.Query.FieldByName('sum_goods').AsInteger
                    ],
                    asoExec) then
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end;
  end
  else
  begin
    //数据库连接失败或异常
    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    Exit;
  end;

  //查询出每个店铺内 每种商品最近一个月的售出份数  并更新到对应字段
  if ASQLDBHelper.SelfQuery('SELECT B.shop_goods_fid,Sum(B.number) as sum_goods_month FROM shop_center.tblorder A '
                      +' LEFT JOIN shop_center.tblorder_goods B '
                      +' ON A.appid=B.appid and A.fid=B.order_fid '
                      +' WHERE A.appid=:appid '
                      +' and A.shop_fid=:shop_fid '
                      +' and A.order_state=''done'' '
                      +' and A.createtime>='''+ FormatDateTime('yyyy-mm-dd hh:mm:mm',Now-(1/24/60)*60*24*30)+''''
                      +' GROUP BY B.shop_goods_fid ',
                      ['appid',
                      'shop_fid'],
                      [AAppId,
                      AShopFID],
                      asoOpen) then
  begin
    if Not ASQLDBHelper.Query.Eof then
    begin
      AGetDataJson:=JsonFromDataSet(ASQLDBHelper.Query,'GoodsSummary');
      for I := 0 to AGetDataJson.A['GoodsSummary'].Length-1 do
      begin
        //将统计好的数量更新到每个商品的对应字段中
        if ASQLDBHelper.SelfQuery('UPDATE shop_center.tblshop_goods '
                      +' SET month_sales=:month_sales '
                      +' WHERE appid=:appid '
                      +' and fid=:fid ',
                      ['appid',
                      'fid',
                      'month_sales'],
                      [AAppId,
                      AGetDataJson.A['GoodsSummary'].O[I].I['shop_goods_fid'],
                      AGetDataJson.A['GoodsSummary'].O[I].F['sum_goods_month']
                      ],
                      asoExec) then
        begin
          //成功
        end;
      end;
    end;
  end
  else
  begin
    //数据库连接失败或异常
    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    Exit;
  end;

end;


