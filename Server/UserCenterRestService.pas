            //查询主播ID  存在  返回FID
            if not ASQLDBHelper.SelfQuery('SELECT user_fid fid FROM shop_center.tblshop_spread '
                                      +'WHERE appid=:appid '
                                      +' and token=:token '
                                      +' and IFNULL(is_deleted,0)=0 ',//没有被删除
                                      ['appid','token'],
                                      [AAppID,ASpreadToken],
                                      asoOpen) then
            begin
              //数据库连接失败或异常
              ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
              Exit;
            end;

            if Not ASQLDBHelper.Query.Eof then
            begin
              AInviterUserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;

              if not ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                            +' SET exp=IFNULL(exp,0)+1 '
                                            +' WHERE appid=:appid '
                                                  +' and fid=:fid ',//没有被删除
                                            ['appid','fid'],
                                            [AAppID,AInviterUserFID],
                                            asoExec) then
              begin
                //数据库连接失败或异常
                ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
                Exit;
              end;

            end
            else
            begin
              //此账号已经被注册
              ADesc:=('邀请人账号不存在或异常');
              Exit;
            end;
          end;
    end;



    //注册的时候提交了地理位置
    ATempLongitude:=0;
    if ALongitudeStr<>'' then
    begin
      TryStrToFloat(ALongitudeStr,ATempLongitude);
    end;
    ATempLatitude:=0;
    if ALatitudeStr<>'' then
    begin
      TryStrToFloat(ALatitudeStr,ATempLatitude);
    end;




      //插入新用户
      //fid改用了字符串了
      if fumamx_open_id<>'' then
      begin
        AUserFID:=//AAppID+'_'+
                  fumamx_open_id;
      end
      else
      begin
        AUserFID:=CreateGUIDString;
      end;


      AFastMsgUserId:=0;
      //如果App启用了IM的功能,那么新建FastMsg用户,规则8位,
      AApp:=GlobalServiceProject.AppList.Find(AAppID);
      if AApp<>nil then
      begin
        if (AApp.is_enable_fastmsg=1) then
        begin
            AFastMsgUserId:=GetMaxFID(ASQLDBHelper,'tbluser','fastmsg_user_id',True);
            if (AApp.fastmsg_webapi_url<>'') and (AApp.fastmsg_key<>'') then
            begin
                try
                  AHttpResponse:=SimpleCallAPI('adduser',
                                              nil,
                                              AApp.fastmsg_webapi_url+'webapi/',
                                              ['key',
                                              'ispost',
                                              'timeout',

                                              'workgroupid',
                                              'userid',
                                              'username',
                                              'usertype',
                                              'userrole',
                                              'userlevel',
                                              'nickname',
                                              'gender',
                                              'departid',
                                              'password',
                                              'canfound',

                                              'email'
                                              ],
                                              [AApp.fastmsg_key,
                                              0,
                                              15000,


                                              0,
                                              AFastMsgUserId,
                                              //开放平台的user_fid做为IM的登录名
                                              AFastMsgUserId,//AUserFID,
                                              0,0,AAppID,AFastMsgUserId,0,0,'123456',1,

                                              AUserFID
                                              ],
                                              '',
                                              ''
                                              );

                  //如果是D区,新注册的用户拉入总群
                  if AAppID='1000' then
                  begin
                      AHttpResponse:=SimpleCallAPI('addgroupmember',
                                    nil,
                                    AApp.fastmsg_webapi_url+'webapi/',
                                    ['key',
                                    'ispost',
                                    'timeout',

                                    'groupid',
                                    'members'
                                    ],
                                    [AApp.fastmsg_key,
                                    0,
                                    15000,


                                    2,
                                    AFastMsgUserId
                                    ],
                                    '',
                                    '');

                      //都加我为好友


                  end;



                finally

                end;
            end
//            else if (AApp.fastmsg_webservice_url<>'') then
//            begin
//                try
//                  AErrorCode := GetFastMsg(True,AApp.fastmsg_webservice_url).AddUser(
//                                              //userid
//                                              AFastMsgUserId,
//                                              //username
//                                              AUserFID,
//                                              0,
//                                              0,
//                                              //所属哪个平台
//                                              AAppID,
//                                              //昵称
//                                              AName,
//                                              1,
//                                              APhone,
//                                              '',
//                                              '',
//                                              '',
//                                              '',
//                                              '',
//                                              '',
//                                              0,
//                                              '',
//                                              '',
//                                              '',
//
//                                              //默认密码123456
//                                              '123456',
//                                              //LowerCase(THashMd5.GetHashString('123456')),
//
//                                              '',
//                                              0);
//
//                  if AErrorCode = ERRORCODE_OK then
//                  begin
//                    uBaseLog.HandleException(nil,'RegisterUser FastMsg.AddUser 成功!');
//                  end
//                  else
//                  if (AErrorCode = ERRORCODE_EXISTS) then
//                  begin
//                    uBaseLog.HandleException(nil,'RegisterUser FastMsg.AddUser 人员id已存在!');
//                  end
//                  else
//                  begin
//                    uBaseLog.HandleException(nil,'RegisterUser FastMsg.AddUser 失败!');
//                  end;
//
//
//                except
//                  on E:Exception do
//                  begin
//                    uBaseLog.HandleException(E,'RegisterUser FastMsg.AddUser');
//                  end;
//                end;
//
//            end
            ;
        end;
      end;

    //APPID:1011 用户注册成功后且有邀请人 将其对应的积分exp+1
//    AExp:=0;
//    if ((AInviterUserFID<>'') and (AInviterUserFID<>'0')) and (AAppID=1011) then AExp:=1;

    if not ASQLDBHelper.SelfQuery_EasyInsert('tbluser',
                                            ['fid',
                                            'appid',
                                            'email',
                                            'phone',
                                            'password',
                                            'name',
                                            'head_pic_path',
                                            'user_type',
                                            'register_type',

                                            'wx_auth_code',
                                            'wx_union_id',
                                            'wx_open_id',
                                            'wx_auth_token',

                                            'alipay_open_id',
                                            'alipay_auth_token',

                                            'apple_open_id',
                                            'apple_auth_token',

                                            'fb_auth_code',
                                            'fb_open_id',
                                            'fb_auth_token',

                                            'tw_auth_code',
                                            'tw_open_id',
                                            'tw_auth_token',


                                            'createtime',
                                            'bind_introducer_fid',

                                            'country',
                                            'province',
                                            'city',
                                            'area',
                                            'addr',


                                            'longitude',
                                            'latitude',

                                            'fastmsg_user_id',


                                            'fumamx_open_id',
                                            'fumamx_auth_token'
                                            ],
                                            [
                                            AUserFID,
                                            AAppID,
                                            AEmail,//邮箱
                                            APhone,
                                            APassword,
                                            AName,
                                            AHeadPicPath,//头像地址
                                            AUserType,
                                            ARegisterType,


                                            '',//微信标识wx_auth_code
                                            AWxUnionId,
                                            AWxOpenId,
                                            AWxAuthToken,

                                            //支付宝
                                            AAlipayOpenId,
                                            AAlipayAuthToken,

                                            //Apple
                                            AAppleOpenId,
                                            AAppleAuthToken,


                                            '',//Facebook标识fb_auth_code
                                            AFbOpenId,
                                            AFbAuthToken,

                                            '',//Twitter标识tw_auth_code
                                            ATwOpenId,
                                            ATwAuthToken,
                                            Now,
                                            AInviterUserFID,

                                            ACountry,
                                            AProvince,
                                            ACity,
                                            AArea,
                                            AAddr,

                                            ATempLongitude,
                                            ATempLatitude,

                                            AFastMsgUserId,

                                            fumamx_open_id,
                                            fumamx_auth_token
                                            ],
                                            ' SELECT * FROM tbluser WHERE fid='+QuotedStr(AUserFID)+'; ',
                                            asoOpen) then
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;

    //获取新注册的用户的UserFID
//    AUserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;
    //返回用户信息
    ADataJson:=JsonFromRecord(ASQLDBHelper.Query);

    //登录Token随机字符串
    ADataJson.S['Key']:=CreateGUIDString;//'123456';
    //生成登陆密钥,以便下次重新登录
    UserCenterServiceModule.GenerateLoginKey(ASQLDBHelper,AAppID,AUserFID,ADataJson.S['name'],app_type,ADataJson,ADesc);

    GlobalServiceProject.FUserAccessTokenList.Add(AAppID,ADataJson.S['fid'],ADataJson.S['name'],ADataJson.S['Key'],app_type);


    //客户端注册   商家端注册不执行   积分送了也没用
    //亿诚生活才需要,其他APP也没有配置积分规则
    if (AUserType=0) and ((AAppID='1004') or (AAppID='1011')) then
    begin

          //查询用户注册积分奖励规则  修改邀请人和被邀请人的积分
          AHttpResponse:=SimpleCallAPI(GlobalServiceProject.GetRuleTypeListRestUrl,
                                                  nil,
                                                  '',
                                                  ['appid','emp_fid','key'],
                                                  [AAppID,0,''],
                                                  GlobalServiceProject.GetAppSignType(AAppID),
                                                  GlobalServiceProject.GetAppSecret(AAppID)
                                                  );
          AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

          if AHttpResponseJson.I['Code']=SUCC then
          begin

                AIsGiftBalanceAfterRegister:=False;
                AGiftScore:=0;
                AGiftIntroducerScore:=0;
                for I := 0 to AHttpResponseJson.O['Data'].A['AppScoreRuleList'].Length-1 do
                begin
                  if (AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].S['rule_type']='invite_regist')
                    or (AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].S['rule_type']=Const_RuleType_InviteRegister) then
                  begin
                    AGiftScore:=AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].F['gift_score'];
                    AGiftIntroducerScore:=AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].F['gift_introducer_score'];
                    Break;
                  end;
                end;


                AGiftPhoneBalance:=2;
                for I := 0 to AHttpResponseJson.O['Data'].A['AppScoreRuleList'].Length-1 do
                begin
                  if (AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].S['rule_type']=Const_RuleType_RegisterGiftPhoneBalance) then
                  begin
                    AGiftPhoneBalance:=AHttpResponseJson.O['Data'].A['AppScoreRuleList'].O[I].F['gift_score'];
                    AIsGiftBalanceAfterRegister:=True;
                    Break;
                  end;
                end;


                //修改邀请人和被邀请人的积分
                AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ChangeUserScoreRestUrl,
                                                      nil,
                                                      '',
                                                      ['appid','user_fid','key',
                                                      'rule_type','gift_to_user_fid',
                                                      'score','order_type','order_fid',
                                                      'giver_user_fid'],
                                                      [AAppID,AUserFID,'',
                                                      Const_RuleType_Register,AUserFID,
                                                      AGiftScore,
                                                      //表示是注册赠送的积分
                                                      Const_RuleType_Register,//'register',
                                                      0,
                                                      0],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                                                      );
                AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

                if AHttpResponseJson.I['Code']=SUCC then
                begin
                  //被邀请人积分修改成功
                end;

                if (AInviterUserFID<>'') and (AInviterUserFID<>'0') then
                begin
                  AGiftCount:=0;
                  //判断当天获取积分的次数  每天每人次只奖励10次
                  if ASQLDBHelper.SelfQuery('SELECT count(*) as gift_count'
                                              +' FROM score_center.tbluser_score_inout '
                                              +' WHERE appid=:appid '
                                              +' and user_fid=:user_fid '
                                              +' and rule_type=:rule_type '
                                              +' and createtime>='''+ FormatDateTime('yyyy-mm-dd',Now)+'''',
                                              ['appid','user_fid','rule_type'],
                                              [AAppID,AInviterUserFID,Const_RuleType_InviteRegister],
                                              asoOpen) then
                  begin
                    if Not ASQLDBHelper.Query.Eof then
                    begin
                      AGiftCount:=ASQLDBHelper.Query.FieldByName('gift_count').AsInteger;
                    end;
                  end
                  else
                  begin
                    //数据库连接失败或异常
                    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
                    Exit;
                  end;

                  if AGiftCount<10 then
                  begin
                    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ChangeUserScoreRestUrl,
                                                          nil,
                                                          '',
                                                          ['appid','user_fid','key',
                                                          'rule_type','gift_to_user_fid',
                                                          'score','order_type','order_fid',
                                                          'giver_user_fid'],
                                                          [AAppID,AInviterUserFID,'',
                                                          Const_RuleType_InviteRegister,AInviterUserFID,
                                                          AGiftIntroducerScore,
                                                          Const_RuleType_InviteRegister,//'invite_regist',
                                                          0,
                                                          0],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                                                          );
                    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

                    if AHttpResponseJson.I['Code']=SUCC then
                    begin
                      //邀请人积分修改成功
                    end;
                  end;


