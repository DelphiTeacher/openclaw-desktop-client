    AppID:String;
    UserFID:String;
    //商品名称
    ShopGoodsName:String;
    //商品的规格,是VIP版、源码版，或者是SAAS版还是私有化版
    ShopGoodsSpecName:String;

    //当前套餐过期时间
    expiresTime:String;

    VIPRights:ISuperObject;
    VIPRightsUsage:ISuperObject;
  public
