    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

//  if Trim(AHeadImg)='' then
//  begin
//    ADesc:=('头像链接不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  if Trim(AName)='' then
  begin
    ADesc:=('名称不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      Exit;
    end;


    ABirthUpdateSQL:='';
    if ABirth<>'' then
    begin
      ABirthUpdateSQL:=' birth='+QuotedStr(ABirth)+', ';
    end;

     //并且是修改了昵称之后，才调用这个接口
    if (AAppID='1011' ) and (ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and fid=:fid '
                              +' and name !=:name '
                              //已经免费修改过一次昵称,接下来要扣积分了
                              +' and IFNULL(is_edited_nickname,0)=1 ' ,
                              ['appid','fid','name'],
                              [AAppID,AUserFID,AName],
                              asoOpen)) then
    begin
      if not ASQLDBHelper.Query.Eof then
      begin
              //扣积分接口
              AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ServerUrl+'scorecenter/gift_score',
                                        nil,
                                        '',
                                        ['appid',
                                        'user_fid',
                                        'key',
                                        'rule_type',
                                        'value',
                                        'gift_to_user_fid',
                                        'order_type',
                                        'order_fid'],
                                        [AAppID,
                                        AUserFID,
                                        '',
                                        Const_RuleType_ChangeNickName,    //积分抵扣
                                        0,
                                        AUserFID,
                                        Const_RuleType_ChangeNickName,   //积分抵扣
                                        0],
                                        GlobalServiceProject.GetAppSignType(AAppID),
                                        GlobalServiceProject.GetAppSecret(AAppID)
                                       );
              AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

              if AHttpResponseJson.I['Code']=SUCC then
              begin
                //可以修改昵称
                AIsEditedNickname:=1;
              end
              else
              begin
                ADesc:=(AHttpResponseJson.S['Desc']);
                Exit;
              end;
      end;
      if IsChangeName(ASQLDBHelper,AAppID,AUserFID,AName,ADesc) then
      begin
        AIsEditedNickname:=1;
      end;
    end;



    //修改用户信息
    if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                              +' SET name=:name, '
                              +' sign=:sign, '
                              + ABirthUpdateSQL
                              +' sex=:sex, '
                              +' head_pic_path=:head_pic_path, '
                              +' second_contactor_name=:second_contactor_name, '
                              +' second_contactor_phone=:second_contactor_phone ,'
                              +' is_edited_nickname=:is_edited_nickname '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              [
                              'name',
                              'sign',
                              //'birth',
                              'sex',
                              'head_pic_path',
                              'second_contactor_name',
                              'second_contactor_phone',
                              'is_edited_nickname',
                              'appid',
                              'fid'
                              ],
                              [
                              AName,
                              ASign,
                              //ABirth,
                              ASex,
                              AHeadImg,
                              ASecondContactorName,
                              ASecondContactorPhone,
                              AIsEditedNickname,
                              AAppID,
                              AUserFID
                              ],
                              asoExec) then
    begin
      //用户修改成功

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    //查询用户
    if QueryUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      //成功
      ADesc:=('用户信息修改成功');
      ACode:=SUCC;

      ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');
    end
    else
    begin
      //失败
      ADesc:=('用户信息修改失败');
      ACode:=FAIL;
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.UpdatePrivateSetting(const AAppID: String;
  const AUserFID, AKey, AMyFocusedPrivacySetting, AMyFansPrivateSetting,
