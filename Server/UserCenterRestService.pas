      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    //修改用户
    if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                              +' SET name=:name, '
                              +' phone=:phone, '
                              +' email=:email, '
                              +' password=:password, '
                              +' user_type=:user_type '
                              +' WHERE appid=:appid '
