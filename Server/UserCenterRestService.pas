  ADataJson:=nil;


  if appid='' then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(program_name)='') then
  begin
    ADesc:=('program_name不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(version)='') then
  begin
    ADesc:=('version不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(platform)='') then
  begin
    ADesc:=('platform不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  try


          AIntfItem:=CommonRestServiceModule.IntfList.Find('app_upgrade');

          if (AIntfItem=nil) then
          begin
            ADesc:=('不存在'+'app_upgrade'+'服务');
            Exit;
          end;


          //查询记录
          if not AIntfItem.GetRecordList(UserCenterServiceModule.DBModule,
