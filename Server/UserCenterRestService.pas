function TUserCenterServiceModule.DoPrepareStart(var AError: String): Boolean;
//var
//  ATimerTask:TTimerTask;
//  ASearchSubscribeSetting:ISuperObject;
//  ASQLDBHelper:TBaseDBHelper;
//  ADesc:String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  {$IFDEF HAS_CONTENT_SEARCH}

  J:Integer;
  AIntfItem:TBaseQueryItem;
  {$ENDIF}

  ASQLDBHelper:TBaseDBHelper;
  AUserAccessToken:TUserAccessToken;
  AIniFile:TIniFile;

  ALicenseInfo:ISuperObject;
  AMessage:String;
  AUserOrderGoodsUseStatus:TUserOrderGoodsUseStatus;
begin
  Result:=Inherited DoPrepareStart(AError);

  {$IFDEF YC}
  FGiveStockShareDividendToUserThread:=TGiveStockShareDividendToUserThread.Create(True);
  FGiveStockShareDividendToUserThread.Start;
  {$ENDIF YC}

  {$IFDEF HAS_FASTMSG}
  FSyncUserToFastmsgUserThread:=TSyncUserToFastmsgUserThread.Create(False);
  {$ENDIF}




  //获取用户的所有令牌

  if not Self.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Exit;
  end;
  try
//      ASQLDBHelper.SelfQuery('INSERT INTO tbluser (createtime,is_deleted,fid,login_user,password,name,role_fid,roles,appid) '
//          +' VALUES  (''2024-11-02 20:06:37'',0,''C13294D24F484BE38BAC861D87B5DDCA'',''66'',''66'',''66'',0,'''',1041);'
//          +'SELECT * from tbluser where fid=''C13294D24F484BE38BAC861D87B5DDCA'' ',[],[],asoOpen);

      //管理端改了admin密码,需要更新管理员账号的密码
      AIniFile:=TIniFile.Create(GetApplicationPath+'Config.ini'{$IFDEF MSWINDOWS}{$ELSE},TEncoding.UTF8{$ENDIF});
      try
        if AIniFile.ReadBool('','NeedChangeAdminPWD',False) then
        begin
          //修改密码,并且需要清除token,防止被人盗用
          ASQLDBHelper.SelfQuery('update tbluser set password=:password,login_key='''' where fid=:fid ',['password','fid'],[AIniFile.ReadString('','ChangeAdminPWD',''),'admin'],asoExec);
          AIniFile.DeleteKey('','NeedChangeAdminPWD');


          //将原token标记为空
          ASQLDBHelper.SelfQuery('UPDATE tbluser_access_token '
                                      +' SET access_token='''' '
                                      +' WHERE user_fid=:user_fid ',
                                      ['user_fid'],
                                      ['admin'],
                                      asoExec);

        end;
      finally
        FreeAndNil(AIniFile);
      end;



//      if not ASQLDBHelper.SelfQuery('SELECT appid,fid,login_key FROM tbluser WHERE IFNULL(login_key,'''')<>'''' ') then
      if not ASQLDBHelper.SelfQuery(GlobalUserAccessTokenClass.GetUserSelectSQL) then
      begin
        ADesc:='获取用户login_key时'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;

      //GlobalServiceProject.FUserAccessTokenList.Clear;
      while not ASQLDBHelper.Query.Eof do
      begin
//        AUserAccessToken:=TUserAccessToken.Create;
//        AUserAccessToken.AppID:=IntToStr(ASQLDBHelper.Query.FieldByName('appid').AsInteger);
//        AUserAccessToken.UserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;
//        AUserAccessToken.AccessToken:=ASQLDBHelper.Query.FieldByName('login_key').AsString;
//        GlobalServiceProject.FUserAccessTokenList.Add(AUserAccessToken);

//        GlobalServiceProject.FUserAccessTokenList.Add(
//                          IntToStr(ASQLDBHelper.Query.FieldByName('appid').AsInteger),
//                          ASQLDBHelper.Query.FieldByName('fid').AsString,
//                          ASQLDBHelper.Query.FieldByName('login_key').AsString//,
////                          ASQLDBHelper.Query.FieldByName('app_type').AsString
//                          );
        GlobalServiceProject.FUserAccessTokenList.Add(ASQLDBHelper.Query);

        ASQLDBHelper.Query.Next;
      end;

      //表关联太慢了
//      if ASQLDBHelper.SelfQuery('SELECT A.*,B.name FROM tbluser_access_token A LEFT JOIN tbluser B ON A.fid=B.fid WHERE access_token<>'''' ') then
      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_access_token WHERE access_token<>'''' ') then
      begin

        while not ASQLDBHelper.Query.Eof do
        begin
//          AUserAccessToken:=TUserAccessToken.Create;
//          AUserAccessToken.AppID:=IntToStr(ASQLDBHelper.Query.FieldByName('appid').AsInteger);
//          AUserAccessToken.UserFID:=ASQLDBHelper.Query.FieldByName('user_fid').AsString;
//          AUserAccessToken.AccessToken:=ASQLDBHelper.Query.FieldByName('access_token').AsString;
//          GlobalServiceProject.FUserAccessTokenList.Add(AUserAccessToken);

          GlobalServiceProject.FUserAccessTokenList.Add(
                          IntToStr(ASQLDBHelper.Query.FieldByName('appid').AsInteger),
                          ASQLDBHelper.Query.FieldByName('user_fid').AsString,
                          ASQLDBHelper.Query.FieldByName('name').AsString,
                          ASQLDBHelper.Query.FieldByName('access_token').AsString,
                          ASQLDBHelper.Query.FieldByName('app_type').AsString
                          );

          ASQLDBHelper.Query.Next;
        end;

      end;

  finally
    Self.DBModule.FreeDBHelperToPool(ASQLDBHelper);
  end;


  {$IFDEF HAS_LICENSE_CHECK}
    //更新管理员的License

    //检测授权先
//    ALicenseInfo:=ISuperObject;
    ALicenseInfo:=GetLicenseFileInfo;
    if ALicenseInfo=nil then ALicenseInfo:=SO();
    if not CheckLicense(GetDeviceCode(OEM_ProductName_EN,TDeviceCodeVersion(ALicenseInfo.I['device_code_ver'])),OEM_ProductName_EN,ALicenseInfo,AMessage) then
    begin
      //检测授权失败,停止服务
      uBaseLog.HandleError(nil,'TUserCenterServiceModule.DoPrepareStart 检测授权失败：'+AMessage);

    end
    else
    begin
      //授权成功

      if ALicenseInfo<>nil then
      begin
        AUserOrderGoodsUseStatus:=TUserOrderGoodsUseStatus.Create(GlobalUserOrderGoodsUseStatusList);
        AUserOrderGoodsUseStatus.AppID:='1040';
        AUserOrderGoodsUseStatus.UserFID:='admin';
        //JetBI
        AUserOrderGoodsUseStatus.ShopGoodsName:=OEM_ProductName_EN;

        //商品的规格,是VIP版、源码版，或者是SAAS版还是私有化版
        AUserOrderGoodsUseStatus.ShopGoodsSpecName:=ALicenseInfo.S['product_type'];

        //授权截止日期
        AUserOrderGoodsUseStatus.expiresTime:=ALicenseInfo.S['lic_end_date'];
        //vip权益
        AUserOrderGoodsUseStatus.VIPRights:=ALicenseInfo.O['vip_rights'];

        GlobalUserOrderGoodsUseStatusList.Add(AUserOrderGoodsUseStatus);
      end;

    end;
  {$ENDIF}


end;

function TUserCenterServiceModule.DoPrepareStop: Boolean;
begin

  {$IFDEF YC}
  if FGiveStockShareDividendToUserThread<>nil then
  begin
    FGiveStockShareDividendToUserThread.Terminate;
    FGiveStockShareDividendToUserThread.WaitFor;
    FreeAndNil(FGiveStockShareDividendToUserThread);
  end;
  {$ENDIF YC}


  {$IFDEF HAS_FASTMSG}
  if FSyncUserToFastmsgUserThread<>nil then
  begin
    FSyncUserToFastmsgUserThread.Terminate;
    FSyncUserToFastmsgUserThread.WaitFor;
    FreeAndNil(FSyncUserToFastmsgUserThread);
  end;
  {$ENDIF}


  GlobalUserOrderGoodsUseStatusList.Clear;

  Result:=Inherited DoPrepareStop;


end;


function TUserCenterServiceModule.login_by_password_sha256(AAppID:String;AUserType:Integer;AUserName, APassword: String; var ADesc: String; var ADataJson: ISuperObject): Boolean;
var
  ACode:Integer;
  ADesc2:String;
  ADataJson2:ISuperObject;
  AUserFid:String;

  AUserPassword:String;

  ASQLDBHelper:TBaseDBHelper;
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;

  ALoginKey:String;
  AUserWhereSQL:String;
  ARegisterLoginType:String;

  AUserAccessToken:TUserAccessToken;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;



  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Exit;
  end;


  if Trim(AUserName)='' then
  begin
    ADesc:=('用户名不能为空');
    Exit;
  end;

  if Trim(APassword)='' then
  begin
    ADesc:=('密码不能为空');
    Exit;
  end;

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Exit;
  end;
  try
        AUserWhereSQL:='';
          AUserWhereSQL:=' AND appid='+AAppID+' ';

          //手机号码或邮箱或用户名登录
          AUserWhereSQL:=AUserWhereSQL+' and (phone='+QuotedStr(AUserName)+' or email='+QuotedStr(AUserName)+' or login_user='+QuotedStr(AUserName)+') ';




                    //手机号码或邮箱或用户名登录
                    if not ASQLDBHelper.SelfQuery(' SELECT * FROM tbluser '
                                                  +' WHERE 1=1 '
                                                  +' and IFNULL(user_type,0)=:user_type '
                                                  //+' and (phone=:phone or email=:email or name=:name) '
                                                  +AUserWhereSQL
                                                  +' and IFNULL(is_deleted,0)=0 ',
                                                  [
                                                  'user_type'//,'phone','email','name'
                                                  ],
                                                  [
                                                  AUserType//,AUserName,AUserName,AUserName
                                                  ],
                                                  asoOpen) then
                    begin
                      //数据库连接失败或异常
                      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
                      Exit;
                    end;

                    if ASQLDBHelper.Query.Eof then
                    begin


                            //不存在此用户
                            ADesc:=('账号不存在');
                            Exit;

                    end;

                    AUserFid:=ASQLDBHelper.Query.FieldByName('fid').AsString;
                    AUserPassword:=ASQLDBHelper.Query.FieldByName('password').AsString;





                        //比对密码
                        if AUserPassword<>APassword then
                        begin

                          //密码不正确
                          ADesc:=('密码不正确');
                          Exit;
                        end;




                    //密码正确
                    ADesc:=('登陆成功');
                    ACode:=SUCC;

                    ADataJson:=JsonFromRecord(ASQLDBHelper.Query);
                    JSonFromDataSetTo(ASQLDBHelper.Query,'User',ADataJson);


        AUserAccessToken:=GlobalServiceProject.FUserAccessTokenList.Find(AAppID,ADataJson.S['fid'],'');

        //服务端的版本
        ADataJson.S['server_version']:=GlobalServiceProject.FVersion;

        //判断Token是不是已经存在
        if AUserAccessToken<>nil then
        begin
            if AUserAccessToken.AccessToken='' then
            begin
              //表示已经退出登录
              AUserAccessToken.AccessToken:=CreateGUIDString;//'123456';
            end;
            //登录Token随机字符串
            ADataJson.S['Key']:=AUserAccessToken.AccessToken;
        end
        else
        begin

            //每次都生成吗？
            //登录Token随机字符串
            ADataJson.S['Key']:=CreateGUIDString;//'123456';

            //不存在,需要生成
            AUserAccessToken:=GlobalServiceProject.FUserAccessTokenList.Add(AAppID,ADataJson.S['fid'],ADataJson.S['name'],ADataJson.S['Key'],'');
        end;




        //生成登陆密钥,以便下次重新登录
        //登陆密钥调整为和ADataJson.S['Key']一致
        GenerateLoginKey(ASQLDBHelper,AAppID,AUserFID,ADataJson.S['name'],'',ADataJson,ADesc);

        ADataJson.A['User'].O[0].S['Key']:=AUserAccessToken.AccessToken;
        ADataJson.A['User'].O[0].S['login_key']:=AUserAccessToken.AccessToken;
        ADataJson.A['User'].O[0].S['server_version']:=GlobalServiceProject.FVersion;



        {$IFDEF NEED_USER_LOGIN_HISTORY}
        //插入登录历史
        //if not
        ASQLDBHelper.SelfQuery('INSERT INTO tbluser_login_history '
                                    +' (appid,user_fid,user_type,user_name,phone_imei,phone_uuid,phone_type,os,os_version,app_version,login_time,login_type) '
                                    +' VALUES '
                                    +' (:appid,:user_fid,:user_type,:user_name,:phone_imei,:phone_uuid,:phone_type,:os,:os_version,:app_version,:login_time,:login_type) ',
                                    ['appid','user_fid','user_type','user_name','phone_imei','phone_uuid','phone_type','os','os_version','app_version','login_time','login_type'],
                                    [AAppID,AUserFid,AUserType,AUserName,'','','','','','',Now,Const_RegisterLoginType_UserName_PassWordSHA256],
                                    asoExec                                                                   //'Windows 7 Service Pack 1 (Version 6.1, Build 7601, 64-bit Edition)'
                                    );// then
        //begin
        //  //插入登录历史
        //  //数据库连接失败或异常
        //  ADesc:='插入登录历史时'+'数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        //  Exit;
        //end;
        {$ENDIF}



  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
  end;


end;

procedure TUserCenterServiceModule.logout_by_userfid(AUserFID: String);
var
  ADesc:String;
var
  ASQLDBHelper:TBaseDBHelper;
begin

  ADesc:='';

  GlobalServiceProject.FUserAccessTokenList.EmptyByUserFID(AUserFID);

  if not Self.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Exit;
  end;
  try

      //生成一个key  返回给客户端  保存到User表中
      if not ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                  +' SET login_key='''' '
                                  +' WHERE fid=:fid ',
                                  ['fid'],
                                  [AUserFID],
                                  asoExec) then
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;



      //将原token标记为空
      if not ASQLDBHelper.SelfQuery('UPDATE tbluser_access_token '
                                  +' SET access_token='''' '
                                  +' WHERE user_fid=:user_fid ',
                                  ['user_fid'],
                                  [AUserFID],
                                  asoExec) then
      begin
      end;


  finally
    Self.DBModule.FreeDBHelperToPool(ASQLDBHelper);
  end;

end;

