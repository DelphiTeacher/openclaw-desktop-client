function TsrvUserCenterRestService.UserUploadPosition(const AAppID:String;const
  AUserFID: String; const AKey: String; const ALongitude, ALatitude: Double;
  const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;

  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  try
    //接口验证用户是否合法
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      Exit;
    end;

    //更新用户经纬度
    if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                            +' SET latitude=:latitude, '
                            +' longitude=:longitude '
                            +' WHERE appid=:appid '
                            +' and fid=:fid ',
                            ['latitude','longitude','appid','fid'],
                            [ALatitude,ALongitude,AAppID,AUserFID],
                            asoExec
                            ) then
    begin
      //更新成功
      ACode:=SUCC;
      ADesc:='用户经纬度更新成功';
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

