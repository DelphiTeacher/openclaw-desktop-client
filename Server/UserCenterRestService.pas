      ADesc:=(AHttpResponseJson.S['Desc']);
      Exit;
    end;

    //获取用户介绍人FID

    AHttpResponse:=GetMyInfo(AAppID,AUserFID,AKey,ARemoteLocation);
    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

    if AHttpResponseJson.I['Code']=SUCC then
    begin
      AIntroducerFID:=AHttpResponseJson.O['Data'].A['User'].O[0].S['bind_introducer_fid'];
      //有介绍人
      if (AIntroducerFID<>'') and (AIntroducerFID<>'0') then
      begin
        AHttpResponse:=SimpleCallAPI(GlobalServiceProject.GetOrderInfoRestUrl,
                          nil,
                          '',
                          ['appid',
                          'user_fid',
                          'key',
                          'order_fid'],
                          [AAppID,
                          AUserFID,
                          AKey,
                          AOrderFID],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                          );
        AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

        if AHttpResponseJson.I['Code']=SUCC then
        begin
//          AGiftScore:=AHttpResponseJson.O['Data'].A['OrderInfo'].O[0].F['gift_score'];
          AUserGoodsMoney:=AHttpResponseJson.O['Data'].A['OrderInfo'].O[0].F['goods_money'];
          AShopFID:=AHttpResponseJson.O['Data'].A['OrderInfo'].O[0].I['shop_fid'];

          //现在改成立即赠送相应比例的余额给介绍人
          AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ChangeUserMoneyRestUrl,
                                      nil,
                                      '',
