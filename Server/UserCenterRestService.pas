function TsrvUserCenterRestService.DelUser(const AAppID:String;const  AEmpFID: String;
  const AKey: String; const AManFID: String;
  const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc,AUserName:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AEmpFID)='') or (Trim(AEmpFID)='0') then
  begin
    ADesc:=('EmpFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AManFID)='') or (Trim(AManFID)='0') then
  begin
    ADesc:=('ManFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    //检查是否是合法的员工
    if Not IsValidEmp(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
    begin

      Exit;
    end;

    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AManFID,ADesc) then
    begin

      Exit;
    end;

    //获取用户名
    if ASQLDBHelper.SelfQuery('SELECT name FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              ['appid',
                              'fid'],
                              [AAppID,
                              AManFID
                              ],
                              asoExec) then
    begin
      //成功
      AUserName:=ASQLDBHelper.Query.FieldByName('name').AsString;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


    //删除用户,假删,只设置是否删除字段is_deleted
    if ASQLDBHelper.SelfQuery('UPDATE tbluser '
                              +' SET is_deleted=1, '
                              +' name=:name '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              [
                              'name',
                              'appid',
                              'fid'
                              ],
                              [
                              '已删除-'+AUserName,
                              AAppID,
                              AManFID
                              ],
                              asoExec) then
    begin
        //用户删除成功
        //成功
        ADesc:=('用户删除成功');
        ACode:=SUCC;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

