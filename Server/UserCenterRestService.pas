//                          AIntroducerFID,
//                          AUserGoodsMoney*AGiftScore,
//                          Const_OrderType_ScoreReback,
//                          AOrderFID,
//                          AUserFID],
//                      GlobalServiceProject.GetAppSignType(AAppID),
//                      GlobalServiceProject.GetAppSecret(AAppID)
//                          );
//          AHttpResponseJson:=TSuperObject.Create(AHttpResponse);
//
//          if AHttpResponseJson.I['Code']=SUCC then
//          begin
//            //成功
//          end
//          else
//          begin
//            ADesc:=(AHttpResponseJson.S['Desc']);
//            Exit;
//          end;

          //通知介绍人
          if DoNoticeUser(ASQLDBHelper,
                          AAppID,
                          AUserFID,
                          AKey,
                          '0',
                          AIntroducerFID,
                          Const_NoticeCalssify_Other,
                          Const_NoticeSubType_GetCommission,
                          '邀请的好友下单成功',
                          '您邀请的好友已完成下单，系统已赠送您'+Format('%.2f',[AGiftMoney])+'余额，请查收!',
                          '您邀请的好友已完成下单，系统已赠送您'+Format('%.2f',[AGiftMoney])+'余额，请查收!',
                          '{"order_fid":'+IntToStr(AOrderFID)+',"notice_sub_type":"'+Const_NoticeSubType_GetCommission+'"}',
                          True,
                          False,
                          ADesc) then
          begin
            //成功
          end
          else
          begin
            //数据库连接失败或异常
            ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
            Exit;
          end;
        end
        else
        begin
          ADesc:=(AHttpResponseJson.S['Desc']);
          Exit;
        end;
      end;
    end
    else
