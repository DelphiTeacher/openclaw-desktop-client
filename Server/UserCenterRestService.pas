function TsrvUserCenterRestService.RegisterUser(const AAppID:String;const
  AUserType: Integer;
  const ARegisterType, APhone, ACaptcha, AEmail,
  AWxUnionId,AWxOpenId, AWxAuthToken,
  AAlipayOpenId, AAlipayAuthToken,
  AFbOpenId, AFbAuthToken,ATwOpenId, ATwAuthToken,
  AName, AHeadPicPath, APassword, AInviteCode, AInviterPhone,
  ACountry,AProvince,ACity,AArea,AAddr,ALongitudeStr,ALatitudeStr,

  AAppleOpenId, AAppleAuthToken,

  ASpreadToken,

  fumamx_open_id,fumamx_auth_token,

  app_type,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc,ASql:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
  I: Integer;

//茶叶生态
var
  AInviterUserFID:String;
  AGiftCount:Integer;
  AUserFID:String;
  AGiftScore,AGiftIntroducerScore:Double;

  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;

  ATempLongitude:Double;
  ATempLatitude:Double;


  AGiftPhoneBalance:Double;
  AIsGiftBalanceAfterRegister:Boolean;

  AApp:TOpenPlatformApp;
  AErrorCode:Integer;
  AFastMsgUserId:Integer;

// 1011
//var
//  AExp : Integer;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


//  if Trim(AName)='' then
//  begin
//    ADesc:=('姓名不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;


  if Trim(AInviterPhone)<>'' then
  begin
    if Not IsMobPhone(AInviterPhone) then
    begin
      ADesc:=('邀请人手机号格式不正确');
      Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
      Exit;
    end;
  end;


  //非第三方账号注册
  if (Trim(AWxOpenId)='')
      and (Trim(AAlipayOpenId)='')
      and (Trim(AAppleOpenId)='')
      and (Trim(AFbOpenId)='')
      and (Trim(ATwOpenId)='')
      and (Trim(fumamx_open_id)='')
       then
  begin
      //手机号码注册,检测手机号
      if ARegisterType=Const_RegisterLoginType_PhoneNum then
      begin
          if Trim(APhone)='' then
          begin
            ADesc:=('手机号不能为空');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;
          if Not IsMobPhone(APhone) then
          begin
            ADesc:=('手机号格式不正确');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;
          if Trim(ACaptcha)='' then
          begin
            ADesc:=('验证码不能为空');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;
      end
      //邮箱注册
      else if ARegisterType=Const_RegisterLoginType_Email then
      begin
          if Trim(AEmail)='' then
          begin
            ADesc:=('邮箱不能为空');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;

          if Not CheckEmail(AEmail) then
          begin
            ADesc:=('邮箱格式不正确');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;
          if Trim(ACaptcha)='' then
          begin
            ADesc:=('验证码不能为空');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;
      end
      //仅用户名密码注册,
      else if ARegisterType=Const_RegisterLoginType_Only_UserName_PassWord then
      begin
          //不检查
      end
      else if ARegisterType=Const_RegisterLoginType_PhoneNum_Captcha then
      begin
          //其他方式？？？？Const_RegisterLoginType_PhoneNum_Captcha??
          if Trim(ACaptcha)='' then
          begin
            ADesc:=('验证码不能为空');
            Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
            Exit;
          end;

      end
      else
      begin
          ADesc:=('不支持该登陆方式'+ARegisterType);
          Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
          Exit;

      end;

  end;







  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //手机号码或邮箱注册时才验证  第三方账号确认未注册才调用注册
    //判断是否已经存在相同的账号
    if (ARegisterType=Const_RegisterLoginType_PhoneNum)
    or  (ARegisterType=Const_RegisterLoginType_Email) then
    begin
          if ARegisterType=Const_RegisterLoginType_PhoneNum then
          begin
            //是否存在相同的手机号
            ASql:=' and phone= '+QuotedStr(APhone);
          end
          else
          if ARegisterType=Const_RegisterLoginType_Email then
          begin
            //是否存在相同的邮箱账号
            ASql:=' and email= '+QuotedStr(AEmail);
          end;



          //判断账号是否已经被注册过了
          if not ASQLDBHelper.SelfQuery('SELECT fid FROM tbluser '
                                        +'WHERE appid=:appid '
                                        +' and user_type=:user_type '
                                        + ASql
                                        +' and IFNULL(is_deleted,0)=0 ',
                                        ['appid','user_type'],
                                        [AAppID,AUserType],
                                        asoOpen) then
          begin
            //数据库连接失败或异常
            ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
            Exit;
          end;



          ASQLDBHelper.Query.First;
          if ASQLDBHelper.Query.Eof then
          begin
            //此账号号没有被注册
          end
          else
          begin
            //此账号已经被注册
            ADesc:=('此账号已经被注册');
            Exit;
          end;


          //要用接口比对
          //比对用户注册验证码
          if not SimpleCallAPI(GlobalServiceProject.CaptchaServer+'check_captcha',
                              nil,
                              '',
                              ['appid',
                              'user_type',
                              'account',
                              'captcha_type',
                              'captcha'],
                              [AAppID,
                              AUserType,
                              Trim(APhone+AEmail),  //APhone AEmail只有可能一个有值
                              Const_CaptchaType_Register,
                              ACaptcha],
                              ACode,
                              ADesc,
                              ADataJson,
                              GlobalServiceProject.GetAppSignType(AAppID),
                              GlobalServiceProject.GetAppSecret(AAppID)
                              ) then
          begin
            Exit;
          end;



          //茶叶生态,亿诚生活
          //根据输入的介绍人的手机号码,找到介绍人
          AInviterUserFID:='0';
          if Trim(AInviterPhone)<>'' then
          begin
            //查询邀请人信息是否存在  存在  返回FID
            if not ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                                      +'WHERE appid=:appid '
                                      +' and phone=:phone '
                                      +' and user_type=0 '   //用户客户邀请
                                      +' and IFNULL(is_deleted,0)=0 ',//并且没有被删除
                                      ['appid','phone'],
                                      [AAppID,AInviterPhone],
                                      asoOpen) then
            begin
              //数据库连接失败或异常
              ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
              Exit;
            end;

            if Not ASQLDBHelper.Query.Eof then
            begin
              AInviterUserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;
            end
            else
            begin
              //此账号已经被注册
              ADesc:=('邀请人账号不存在或异常');
              Exit;
            end;
          end;

          //APPID:1011 根据游戏推广唯一标识Token查询User_fid作为推广人
