function TsrvUserCenterRestService.AddSuggestion(const AAppID:String;
  const AUserFID: String; const AKey, AContent, APic1Path, APic2Path, APic3Path,
  APic4Path, APic5Path, APic6Path, ARemoteLocation: String): String;
var
  ACode,ASuggestionFID:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;

//  ADestDir:String;
  AUserJson:ISuperObject;
  AServiceUserJson:ISuperObject;
  AHttpResponse:String;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:='AppID不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  //未登录的用户也能提建议
//  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
//  begin
//    ADesc:='UserFID不能为空';
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  //文本为空
  if AContent='' then
  begin
    ADesc:='文本内容不能为空';
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


//    //检查是否是合法的用户
//    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
//    begin
//
//      Exit;
//    end;

    //插入新意见
    if ASQLDBHelper.SelfQuery('INSERT INTO tbluser_suggestions'
                              +' (appid, user_fid, content, pic1path, pic2path, pic3path, pic4path, pic5path, pic6path, createtime) '
                              +' VALUES '
                              +' (:appid,:user_fid,:content,:pic1path,:pic2path,:pic3path,:pic4path,:pic5path,:pic6path,:createtime); '
                              +' SELECT last_insert_id() as fid; ',
                              ['appid',
                              'user_fid',
                              'content',
                              'pic1path',
                              'pic2path',
                              'pic3path',
                              'pic4path',
                              'pic5path',
                              'pic6path',
                              'createtime'],
                              [
                              AAppID,
                              AUserFID,
                              AContent,
                              APic1Path,
                              APic2Path,
                              APic3Path,
                              APic4Path,
                              APic5Path,
                              APic6Path,
                              Now
                              ],
                              asoOpen) then
    begin
        //意见添加成功
        ASuggestionFID:=ASQLDBHelper.Query.FieldByName('fid').AsInteger;

    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;


    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_suggestions '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              ['appid','fid'],
                              [AAppID,
                              ASuggestionFID],
                              asoOpen) then
    begin

      if Not ASQLDBHelper.Query.Eof then
      begin
        //意见查询成功
        //意见存在
        ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'Suggestion');

        //成功
        ADesc:='意见添加成功';
        ACode:=SUCC;
      end
      else
      begin
        //失败
        ADesc:='意见添加失败';
        Exit;
      end;

    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;



    //发送即时消息给客服
    if (GlobalServiceProject.AppList.Find(AAppID)<>nil)
      and (GlobalServiceProject.AppList.Find(AAppID).is_enable_fastmsg=1)
      and (GlobalServiceProject.AppList.Find(AAppID).service_user_fid<>'') then
    begin

        if not UserCenterServiceModule.AnonymousGetUserPublicInfo(ASQLDBHelper,AAppID,GlobalServiceProject.AppList.Find(AAppID).service_user_fid,ADesc,AServiceUserJson) then
        begin
          Exit;
        end;



        AUserJson:=TSuperObject.Create();
        AUserJson.I['fastmsg_user_id']:=1;
        if AUserFID<>'' then
        begin
          if not UserCenterServiceModule.AnonymousGetUserPublicInfo(ASQLDBHelper,AAppID,AUserFID,ADesc,AUserJson) then
          begin
            Exit;
          end;
        end;



        AHttpResponse:=SimpleCallAPI('sendmsg',
                                      nil,
                                      GlobalServiceProject.AppList.Find(AAppID).fastmsg_webapi_url+'webapi/',
                                      ['key',
                                      'ispost',
                                      'timeout',

                                      'sender',
                                      'receiver',
                                      'content'
                                      ],
                                      [GlobalServiceProject.AppList.Find(AAppID).fastmsg_key,
                                      0,
                                      15000,

                                      //发送人
                                      AUserJson.I['fastmsg_user_id'],
                                      //接收人
                                      AServiceUserJson.I['fastmsg_user_id'],
                                      //内容
                                      AContent
                                      ],
                                      '',
                                      ''
                                      );

    end;



  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.AddUser(const AAppID:String;const  AEmpFID: String;
  const AKey, APhone, AEmail, APassword, AUserType, AName, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;

  AUserFID:String;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if Trim(AName)='' then
  begin
    ADesc:=('姓名不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APhone)='' then
  begin
    ADesc:=('手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(APhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AEmail)='' then
  begin
    ADesc:=('邮箱不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not CheckEmail(AEmail) then
  begin
    ADesc:=('邮箱格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APassword)='' then
  begin
    ADesc:=('密码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    //检查是否是合法的员工
    if Not IsValidUser(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
    begin

      Exit;
    end;


    //判断用户是否存在
    if ASQLDBHelper.SelfQuery('SELECT fid FROM tbluser '
                              +'WHERE appid=:appid '
                              +' and (phone=:phone or email=:email) ',
                              ['appid','phone','email'],
                              [AAppID,APhone,AEmail],
                              asoOpen) then
    begin
      ASQLDBHelper.Query.First;
      if ASQLDBHelper.Query.Eof then
      begin
        //此手机没有被注册
      end
      else
      begin
        //此手机号已经被注册
        ADesc:=('此手机号或邮箱已经被注册');
        Exit;
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


    //插入新用户
    AUserFID:=CreateGUIDString;
    if ASQLDBHelper.SelfQuery('INSERT INTO tbluser'
                              +' (fid,appid,phone,email,name,password,'
                              +' user_type,register_type,createtime) '
                              +' VALUES '
                              +' (:appid,:phone,:email,:name,:password,'
                              +' :user_type,:register_type,:createtime); '
                              +' SELECT last_insert_id() as fid; ',
                              ['appid','phone','email','name','password','user_type',
                              'register_type','createtime'],
                              [
                              AUserFID,
                              AAppID,
                              APhone,
                              AEmail,
                              AName,
                              APassword,
                              AUserType,
                              Const_RegisterLoginType_PhoneNum,
                              Now
                              ],
                              asoOpen) then
    begin
        //添加成功
//        AUserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;

    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;

    //查询用户,返回添加的用户信息
    if QueryUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
        //成功
        ADesc:=('用户添加成功');
        ACode:=SUCC;

        ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');

    end
    else
    begin
       ADesc:=('用户添加失败');
       ACode:=FAIL;
       Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

function TsrvUserCenterRestService.AddUserBankcard(const AAppID:String;const
  AUserFID: String; const AKey, ABankcardAccount, ABankcardName, ABankcardType:String;
  const AIsDefault:Integer;const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
  AFid:Integer;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //为0时 表示平台银行卡信息
  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardAccount)='' then
  begin
    ADesc:=('BankcardAccount不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardName)='' then
  begin
    ADesc:=('BankcardName不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ABankcardType)='' then
  begin
    ADesc:=('BankcardType不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (AIsDefault<>0) and (AIsDefault<>1) then
  begin
    ADesc:=('IsDefault不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    if (Trim(AUserFID)<>'') and (Trim(AUserFID)<>'0') then
    begin
      if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
      begin
        ADesc:=('用户不合法');
        Exit;
      end;
    end;

    //添加用户银行卡信息
    if ASQLDBHelper.SelfQuery('INSERT INTO tbluser_bankcard_info '
                            +' (appid,user_fid,bankcard_account,bankcard_name,bankcard_type,is_default,createtime) '
                            +' VALUES '
                            +' (:appid,:user_fid,:bankcard_account,:bankcard_name,:bankcard_type,:is_default,:createtime); '
                            +' SELECT last_insert_id() as fid; ',
                            ['appid','user_fid','bankcard_account','bankcard_name','bankcard_type','is_default','createtime'],
                            [AAppID,AUserFID,ABankcardAccount, ABankcardName, ABankcardType,AIsDefault,Now],
                            asoOpen) then
    begin
      AFid:=ASQLDBHelper.Query.FieldByName('fid').AsInteger;
      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_bankcard_info '
                                  +' WHERE appid=:appid '
                                  +' and fid=:fid '
                                  +' and IFNULL(is_deleted,0)=0 ',
                                  ['appid','fid'],
                                  [AAppID,
                                  AFid
                                  ],
                                  asoOpen) then
      begin
        if Not ASQLDBHelper.Query.Eof then
        begin
          ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'UserBankcardInfo');
          ACode:=SUCC;
          ADesc:=('添加用户银行卡信息成功');
        end
        else
        begin
          ADesc:=('添加失败-找不到记录');
          Exit;
        end;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      end;


    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

