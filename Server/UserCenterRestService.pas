  AUserFID: String; const AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try




    //判断用户是否合法
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin

      Exit;
    end;





    //再查询用户通知的总未读数
    if ASQLDBHelper.SelfQuery('SELECT count(A.fid) as notice_unread_count '
                              +' FROM tbluser_notice A '
                              +' LEFT JOIN tbluser_notice_read_state B '
                              +' ON A.appid=B.appid and A.fid=B.notice_fid '
                              +' WHERE A.appid=:appid '
                              +' and (A.user_fid=:user_fid OR A.user_fid='''') '
                              +' and IFNULL(A.is_deleted,0)=0 '
                              +' and IFNULL(B.is_readed,0)=0 ',
                              ['appid',
                              'user_fid'],
                              [
                              AAppID,
                              AUserFID
                              ],
                              asoOpen) then
    begin

      ADataJson:=TSuperObject.Create;
      ADataJson.I['notice_unread_count']:=ASQLDBHelper.Query.FieldByName('notice_unread_count').AsInteger;


      //成功
      ADesc:=('查询用户通知的总未读数成功');
      ACode:=SUCC;


    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

