function TsrvUserCenterRestService.get_user_has_power(const AAppID: String;
  const AUserFID, AKey, APower, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  AHasPower:Boolean;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  AHasPower:=False;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    ADataJson:=TSuperObject.Create();
    ADataJson.B['HasPower']:=False;


    //查询用户等级权限
    if not ASQLDBHelper.SelfQuery(' SELECT A.*,B.level, '
                                    //是否已获得
                                    +' (B.level>=A.need_user_level) AS is_getted '
                                    +' FROM tblpower A '
                                    +' LEFT JOIN tbluser B ON A.appid=B.appid'
                                    +' WHERE A.appid=:appid '
                                    +' AND B.fid=:user_fid '
                                    +' AND A.name=:power ',
                                    ['appid','user_fid','power'
                                    ],
                                    [
                                    AAppID,AUserFID,APower
                                    ],
                                    asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;



    if ASQLDBHelper.Query.Eof then
    begin
      //没有这个权限项，说明不需要权限
      //成功
      ADesc:=('有权限');
      ADataJson.B['HasPower']:=True;
      AHasPower:=True;
      ACode:=SUCC;
      Exit;
    end;


    if ASQLDBHelper.Query.FieldByName('level').AsInteger<ASQLDBHelper.Query.FieldByName('need_user_level').AsInteger then
    begin

      ADesc:=('权限不足,需要用户等级为'+IntToStr(ASQLDBHelper.Query.FieldByName('need_user_level').AsInteger)+'级');
      ACode:=SUCC;
      Exit;
    end;




    //没有这个权限项，说明不需要权限
    //成功
    ADesc:=('有权限');
    ADataJson.B['HasPower']:=True;
    AHasPower:=True;
    ACode:=SUCC;
    Exit;




  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson,'',nil,['HasPower'],[AHasPower]).AsJSON;
  end;

end;

