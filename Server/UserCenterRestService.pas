function TsrvUserCenterRestService.update_my_info_post(const AKey,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  AStringStream:TStringStream;

  ACode2:Integer;
  ADesc2:String;
  ADataJson2:ISuperObject;

  AAppID:String;
  AUserFID:String;
//  AUserTypeInt:Integer;
  ARecordDataJson:ISuperObject;
  AIntfItem:TCommonRestIntfItem;
  AUserAccessToken:TUserAccessToken;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;



  AStringStream:=TStringStream.Create('',TEncoding.UTF8);
  try
    AStringStream.LoadFromStream(RequestStream);
    try
      ARecordDataJson:=SO(AStringStream.DataString);

    except
      on E:Exception do
      begin
        ADesc:=('RequestStream不是合法的JsonArray格式');
        Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
        Exit;
      end;
    end;
  finally
    FreeAndNil(AStringStream);
  end;


  try
      AUserAccessToken:=GlobalServiceProject.FUserAccessTokenList.Find(AKey);

      if AUserAccessToken=nil then
      begin
        ADesc:='key:'+AKey+'无效或已过期';
        Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
        Exit;
      end;
      AAppID:=AUserAccessToken.AppID;
      AUserFID:=AUserAccessToken.UserFID;




      AIntfItem:=CommonRestServiceModule.IntfList.Find('user');
      if AIntfItem=nil then
      begin
        ADesc:='user接口不存在';
        Exit;
      end;
      if not ARecordDataJson.Contains('appid') then
      begin
        ARecordDataJson.S['appid']:=AAppID;
      end;
      if not ARecordDataJson.Contains('user_fid') then
      begin
        ARecordDataJson.S['user_fid']:=AUserFID;
      end;

      //修改用户资料
      AIntfItem.UpdateRecord(AIntfItem.DBModule,
                            nil,
                            AAppID,
                            ARecordDataJson,
                            ConvertJsonArray(GetWhereCondition('AND','fid','=',AUserFID)).AsJson,
                            '',
                            ACode,
                            ADesc,
                            ADataJson
                            );


  finally
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

