function TsrvUserCenterRestService.UserSignIn(const AAppID: String;
  const AUserFID: String;  const AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;

  I,ASignFID:Integer;
//  ASignScore:Double;
var
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  try
    //检查是否是合法的用户
    //if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then Exit;

    //查询是否重复签到
    if not ASQLDBHelper.SelfQuery('SELECT COUNT(*) CNT FROM shop_center.tbluser_signed_shop '
                                +' WHERE appid=:appid and IFNULL(is_deleted,0)=0 '
                                +' AND user_fid=:user_fid and createtime>=CURDATE() ',
                                ['appid','user_fid'],
                                [AAppID,AUserFID],
                                asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;
    if ASQLDBHelper.Query.FieldByName('CNT').AsInteger>0 then
    begin
      ADesc:=('请勿重复签到!');
      Exit;
    end;



    //添加签到记录
    if not ASQLDBHelper.SelfQuery('INSERT INTO shop_center.tbluser_signed_shop '
                            +' (appid,user_fid,createtime) '
                            +' VALUES '
                            +' (:appid,:user_fid,:createtime); '
                            +' SELECT last_insert_id() as fid; ',
                            ['appid','user_fid','createtime'],
                            [AAppID,AUserFID,Now],
                            asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit
    end;


    ASignFID:=ASQLDBHelper.Query.FieldByName('fid').AsInteger;




//    //获取连续签到天数
//    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.UserCenterServer+'get_keep_sign_in_days',
//                                            nil,
//                                            '',
//                                            ['appid','user_fid','key'],
//                                            [AAppID,AUserFID,''],
//                                            GlobalServiceProject.GetAppSignType(AAppID),
//                                            GlobalServiceProject.GetAppSecret(AAppID)
//                                            );
//    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);
//    if AHttpResponseJson.I['Code']=SUCC then ASignScore:=AHttpResponseJson.O['Data'].I['days'];




    //获取签到积分规则
    //更新用户的积分
//    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ScoreCenterServer+'calc_gift_score',
//                                            nil,
//                                            '',
//                                            ['appid','user_fid','key','rule_type','value'],
//                                            [AAppID,AUserFID,'',Const_RuleType_UserSignIn,ASignScore],
//                                            GlobalServiceProject.GetAppSignType(AAppID),
//                                            GlobalServiceProject.GetAppSecret(AAppID)
//                                            );
//    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);
//    if AHttpResponseJson.I['Code']=SUCC then
//    begin
//      ASignScore:=AHttpResponseJson.O['Data'].F['gift_score'];
//    end;



    //修改签到人的积分
//    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ScoreCenterServer+'direct_oper_score',
//                                          nil,
//                                          '',
//                                          ['appid','user_fid','key',
//                                          'rule_type','gift_to_user_fid',
//                                          'score','order_type','order_fid',
//                                          'giver_user_fid'],
//                                          [AAppID,AUserFID,'',
//                                          Const_RuleType_UserSignIn,AUserFID,
//                                          ASignScore,
//                                          //表示是签到赠送的积分
//                                          Const_RuleType_UserSignIn,
//                                          0,
//                                          0],
//                                          GlobalServiceProject.GetAppSignType(AAppID),
//                                          GlobalServiceProject.GetAppSecret(AAppID)
//                                          );
//    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);
//    if AHttpResponseJson.I['Code']<>SUCC then
//    begin
//      ADesc:='签到失败！';
//      Exit;
//    end;
    //修改签到人的积分
    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ScoreCenterServer+'gift_score',
                                          nil,
                                          '',
                                          ['appid',
                                          'user_fid',
                                          'key',
                                          'rule_type',
                                          'value',
                                          'gift_to_user_fid',
                                          'order_type',
                                          'order_fid'],
                                          [AAppID,
                                          AUserFID,
                                          '',
                                          Const_RuleType_UserSignIn,
                                          0,
                                          AUserFID,
                                          //表示是签到赠送的积分
                                          Const_RuleType_UserSignIn,
                                          0],
                                          GlobalServiceProject.GetAppSignType(AAppID),
                                          GlobalServiceProject.GetAppSecret(AAppID)
                                          );
    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);
    if AHttpResponseJson.I['Code']<>SUCC then
    begin
      ADesc:=AHttpResponseJson.S['Desc'];
      Exit;
    end;



    //查询签到信息
    if not ASQLDBHelper.SelfQuery('SELECT A.*,B.NAME,B.score all_score,C.score add_score '
                              +' FROM shop_center.tbluser_signed_shop A '
                              +' LEFT JOIN tbluser B ON A.appid=B.appid AND A.user_fid=B.fid '
                              +' LEFT JOIN score_center.tbluser_score_inout C ON A.appid=C.appid and A.user_fid=C.user_fid AND C.rule_type='+QuotedStr(Const_RuleType_UserSignIn)
                              +' WHERE A.appid=:appid  '
                              +' AND A.fid=:fid ORDER BY C.createtime desc LIMIT 0,1',
                              ['appid','fid'],
                              [AAppID,ASignFID],
                              asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


    //成功
    ADesc:=('签到成功');
    ACode:=SUCC;
    ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'SignIn');


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;
end;

