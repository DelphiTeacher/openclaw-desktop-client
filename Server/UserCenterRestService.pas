procedure TUserCenterServiceModule.GenerateLoginKey(ASQLDBHelper:TBaseDBHelper;
                                                     AAppID:String;
                                                     AUserFID:String;
                                                     AUserName:String;
                                                     app_type:String;
                                                     ADataJson:ISuperObject;
                                                     var ADesc:String
                                                      );
var
  ALoginKey:String;
begin

  //生成登陆密钥,以便下次重新登录
  ALoginKey:=ADataJson.S['Key'];//FormatDateTime('YYYYMMDDHHMMSS',Now)+'-'+AUserFid;

  ADataJson.S['login_key']:='';
  //生成一个key  返回给客户端  保存到User表中
  if not ASQLDBHelper.SelfQuery('UPDATE tbluser '
                              +' SET login_key=:login_key '
                              +' WHERE '
//                              +' appid=:appid '
//                              +' and '
                              +' fid=:fid ',
                              ['login_key',
                              //'appid',
                              'fid'],
                              [
                              ALoginKey,
                              //同一个用户ID可以登不同的APPID,而且user_fid已经能确定是哪个用户
                              //AAppID,
                              AUserFid
                              ],
                              asoExec) then
  begin
    //数据库连接失败或异常
    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    Exit;
  end;

  //存在则更新，不存在在则插入
//  if not ASQLDBHelper.SelfQuery_EasyInsert('tbluser_access_token',
//                  ['appid','user_fid','access_token','app_type','createtime'],
//                  [AAppID,AUserFID,ALoginKey,app_type,StdDateTimeToStr(Now)]) then
//  begin
//    //数据库连接失败或异常
////    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
////    Exit;
//  end;
  if not ASQLDBHelper.SelfQuery_EasySave('tbluser_access_token',

                  ['appid','user_fid','name','access_token','app_type','createtime'],
                  [AAppID,AUserFID,AUserName,ALoginKey,app_type,StdDateTimeToStr(Now)],

                  ['name','access_token','update_time'],
                  [AUserName,ALoginKey,StdDateTimeToStr(Now)],


                  'WHERE appid=:appid AND user_fid=:user_fid AND app_type=:app_type',

                  ['appid','user_fid','app_type'],
                  [AAppID,AUserFID,ALoginKey]
                  ) then
  begin
    //数据库连接失败或异常
//    ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
//    Exit;
  end;

  //成功
  ADataJson.S['login_key']:=ALoginKey;

end;

function TsrvUserCenterRestService.GeneratInviteCode(const AAppID:String;const
  AUserFID: String; const AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  ACode2:Integer;
  ADesc2:String;
  ADataJson2:ISuperObject;
var
  AInviteCode:String;
  ASQLDBHelper:TBaseDBHelper;
var
  ATableItem:TCommonRestIntfItem;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //查询用户
    if IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      //用户存在且正常使用

      //生成的邀请码不能重复
      repeat
          AInviteCode:=GetRandStr(6,False,True,True);

          if ASQLDBHelper.SelfQuery('SELECT * FROM tblinvite_code'
                                    +' WHERE appid=:appid '
                                    +' and invite_code=:invite_code ',
                                    ['appid','invite_code'],
                                    [
                                    AAppID,
                                    AInviteCode
                                    ],
                                    asoOpen) then
          begin
              //查询成功
          end
          else
          begin
              //数据库连接失败或异常
              ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
              Exit;
          end;

        //查询到此邀请码唯一
      until ASQLDBHelper.Query.Eof;

      //插入此邀请码
      if ASQLDBHelper.SelfQuery('INSERT INTO tblinvite_code'
                                +'(appid,user_fid,invite_code,createtime,timeout) '
                                +'VALUES '
                                +'(:appid,:user_fid,:invite_code,:createtime,:timeout)',
                                ['appid','user_fid','invite_code','createtime','timeout'],
                                [
                                AAppID,
                                AUserFID,
                                AInviteCode,
                                Now,
                                //超时时间十分钟
                                10*60
                                ],
                                asoExec) then
      begin





//          //获取APP的信息,里面包含服务器域名
//          if not CommonRestServiceModule.GetRecord('app',
//                                            nil,
//                                            AAppID,
//                                            GetWhereConditions(['fid'],[AAppID]),
//                                            //自定义查询条件
//                                            '',
//                                            '',
//                                            ACode2,ADesc2,ADataJson2) then
//          begin
//            ACode:=ACode2;
//            ADesc:=ADesc2;
//            Exit;
//          end;
          ATableItem:=nil;

          ATableItem:=CommonRestServiceModule.IntfList.Find('app');

          if (ATableItem=nil) then
          begin
            ADesc:=('不存在'+'app'+'服务');
            Exit;
          end;


          //查询记录
          if ATableItem.GetRecord(
                              ATableItem.DBModule,
                              ASQLDBHelper,
                              AAppID,
                              GetWhereConditions(['fid'],[AAppID]),
                              '',
                              '',
                              ACode2,
                              ADesc2,
                              ADataJson2,
                              True,
                              1
                              ) then
          begin
            ACode:=ACode2;
            ADesc:=ADesc2;
            Exit;
          end;



          //成功
          ADesc:=('生成邀请码成功');
          ACode:=SUCC;


          ADataJson:=TSuperObject.Create();
          ADataJson.S['InviteCode']:=AInviteCode;
          ADataJson.S['TimeOut']:='10分钟';

          //获取该应用的官网链接
          //二维码地址(跳转到注册页面)
          ADataJson.S['InviteCode_BarCode_Url']:=ADataJson2.S['server']+'/register?invite_code='+AInviteCode;


      end
      else
      begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
          Exit;
      end;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;


