function TsrvUserCenterRestService.ChangPhoneNum(const AAppID:String;const AUserType: Integer; const AKey,
  AOldPhone, AOldPassword, ANewPhone, ACaptcha,
  ARemoteLocation: String): String;
var
  ACode:Integer;AUserFID:String;
  ADesc:String;
  ADataJson:ISuperObject;
var
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AOldPhone)='' then
  begin
    ADesc:=('旧手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(AOldPhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ANewPhone)='' then
  begin
    ADesc:=('新手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(ANewPhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ACaptcha)='' then
  begin
    ADesc:=('验证码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //判断旧手机号是否存在
    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and phone=:phone',
                              ['appid',
                              'user_type',
                              'phone'],
                              [AAppID,
                              AUserType,
                              AOldPhone],
                              asoOpen) then
    begin
        ASQLDBHelper.Query.First;
        if ASQLDBHelper.Query.Eof then
        begin
          //不存在此手机号
          ADesc:=('旧手机号未注册');
          Exit;
        end
        else
        begin
          AUserFID:=ASQLDBHelper.Query.FieldByName('fid').AsString;
          //旧密码不正确
          if ASQLDBHelper.Query.FieldByName('password').AsString<>AOldPassword then
          begin
            ADesc:=('旧密码不正确');
            Exit;
          end;
        end;
    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;


    //判断新手机号是否已经被注册
    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and phone=:phone',
                              ['appid',
                              'user_type',
                              'phone'],
                              [AAppID,
                              AUserType,
                              ANewPhone],
                              asoOpen) then
    begin
        ASQLDBHelper.Query.First;
        if ASQLDBHelper.Query.Eof then
        begin
            //不存在此手机号
            //表示此手机号没有注册过
        end
        else
        begin
          //此手机号已经被注册
          ADesc:=('新手机号已经被注册');
          Exit;
        end;
    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;

    //核对验证码是否正确
    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.CaptchaServer+'check_captcha',
                                    nil,
                                    '',
                                    ['appid',
                                    'user_type',
                                    'account',
                                    'captcha_type',
                                    'captcha'],
                                    [AAppID,
                                    AUserType,
                                    ANewPhone,
                                    Const_CaptchaType_Register,
                                    ACaptcha],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                                    );
    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

    if AHttpResponseJson.I['Code']=SUCC then
    begin
      //验证码正确  修改手机号码
      if ASQLDBHelper.SelfQuery(' UPDATE tbluser '
                                +' SET phone=:phone '
                                +' WHERE appid=:appid '
                                +' and fid=:fid'
                                +' and user_type=:user_type',
                                ['phone',
                                'appid',
                                'fid',
                                'user_type'],
                                [ANewPhone,
                                AAppID,
                                AUserFID,
                                AUserType],
                                asoExec
                                ) then
      begin
        ADesc:=('更换手机号码成功');
        ACode:=SUCC;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:=('验证码不正确');
      Exit;
    end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

