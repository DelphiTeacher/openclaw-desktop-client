function TsrvUserCenterRestService.GetPrivateSetting(const AAppID: String;
  const AUserFID, AKey,  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin
  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  try
    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      Exit;
    end;

   //查询用户
    if NOT ASQLDBHelper.SelfQuery('SELECT my_focused_privacy_setting,my_fans_private_setting,my_visitor_privacy_setting FROM `user_center`.`tbluser` '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              [
                              'appid',
                              'fid'
                              ],
                              [
                              AAppID,
                              AUserFID
                              ],
                              asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;


    if ASQLDBHelper.Query.Eof then
    begin
      ADesc:=('用户不存在');
      Exit;
    end;


    //成功
    ADesc:=('查询用户成功');
    ACode:=SUCC;

    ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'User');
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

