function TsrvUserCenterRestService.ReSetForgetPassword(const AAppID:String;const AUserType: Integer;
  const APhone, ACaptcha, APassword, ARePassword,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
var
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;




  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APhone)='' then
  begin
    ADesc:=('手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Not IsMobPhone(APhone)) and (Not CheckEmail(APhone)) then
  begin
    ADesc:=('手机号或邮箱格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if Trim(ACaptcha)='' then
  begin
    ADesc:=('验证码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APassword)='' then
  begin
    ADesc:=('密码不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ARePassword)='' then
  begin
    ADesc:=('密码确认不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if APassword<>ARePassword then
  begin
    ADesc:=('两次输入的密码不相同');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  //验证码检验成功


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    if ASQLDBHelper.SelfQuery('SELECT fid FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type '
                              +' and (phone=:phone or email=:email) ',
                              ['appid',
                              'user_type',
                              'phone',
                              'email'],
                              [AAppID,
                              AUserType,
                              APhone,
                              APhone],
                              asoOpen) then
    begin
      ASQLDBHelper.Query.First;
      if not ASQLDBHelper.Query.Eof then
      begin
        //存在此手机

        //用接口比对验证码
        AHttpResponse:=SimpleCallAPI(GlobalServiceProject.CaptchaServer+'check_captcha',
                                            nil,
                                            '',
                                            ['appid',
                                            'user_type',
                                            'account',
                                            'captcha_type',
                                            'captcha'],
                                            [AAppID,
                                            AUserType,
                                            APhone,
                                            Const_CaptchaType_ForgetPassword,
                                            ACaptcha],
                                            GlobalServiceProject.GetAppSignType(AAppID),
                                            GlobalServiceProject.GetAppSecret(AAppID)
                                            );
        AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

        if AHttpResponseJson.I['Code']=SUCC then
        begin
          //存在此用户
          //重置密码
          if ASQLDBHelper.SelfQuery('UPDATE tbluser SET password=:password '
                                  +'WHERE appid=:appid '
                                  +' and user_type=:user_type '
                                  +' and (phone=:phone or email=:email)',
                                  ['password','appid','user_type','phone','email'],
                                  [APassword,AAPPID,AUserType,APhone,APhone],
                                  asoExec) then
          begin
              //密码重置成功
              ADesc:=('密码重置成功');
              ACode:=SUCC;
          end
          else
          begin
              //数据库连接失败或异常
              ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
          end;
//
        end
        else
        begin
          //数据库连接失败或异常
          ADesc:=('验证码不正确');
          Exit;
        end;

      end
      else
      begin
        //此手机号未被注册
        ADesc:=('此手机号或邮箱未注册');
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.SendBindPhoneNumCaptcha(const AAppID:String;const
  AUserType: Integer; const AKey, APhone, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ACaptcha:String;
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (AUserType<0) or (AUserType>3) then
  begin
    ADesc:=('用户类型不存在');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(APhone)='' then
  begin
    ADesc:=('手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if Not IsMobPhone(APhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //将验证码保存到数据库中,并十分钟有效

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //判断新手机号是否已经被注册
    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and phone=:phone',
                              ['appid',
                              'user_type',
                              'phone'],
                              [AAppID,
                              AUserType,
                              APhone],
                              asoOpen) then
    begin
        ASQLDBHelper.Query.First;
        if ASQLDBHelper.Query.Eof then
        begin
            //不存在此手机号
            //表示此手机号没有注册过
        end
        else
        begin
          //此手机号已经被注册
          ADesc:=('手机号已经被注册');
          Exit;
        end;
    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;

    //不能频繁发送验证码
    //一分钟之内只能发送一次
    //查询出上次发送注册验证码的时间
    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.SendCaptchaRestUrl,
                    nil,
                    '',
                    ['appid',
                    'user_type',
                    'account',
                    'captcha_type'],
                    [AAppID,
                    AUserType,
                    APhone,
                    Const_CaptchaType_BindPhoneNum
                    ],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                    );
    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

    if AHttpResponseJson.I['Code']=SUCC then
    begin
      ADesc:=('验证码发送成功');
      ACode:=SUCC;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:=('验证码发送失败 '+AHttpResponseJson.S['Desc']);
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.SendChangPhoneNumCaptcha(const AAppID:String;const AUserType: Integer;
  const AKey, AOldPhone, AOldPassword, ANewPhone,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ACaptcha:String;
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;

  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AOldPhone)='' then
  begin
    ADesc:=('旧手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Not IsMobPhone(AOldPhone) then
  begin
    ADesc:=('手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ANewPhone)='' then
  begin
    ADesc:=('新手机号不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if Not IsMobPhone(ANewPhone) then
  begin
    ADesc:=('新手机号格式不正确');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  //将验证码保存到数据库中,并十分钟有效

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try



    //判断旧手机号是否存在
    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and phone=:phone',
                              ['appid',
                              'user_type',
                              'phone'],
                              [AAppID,
                              AUserType,
                              AOldPhone],
                              asoOpen) then
    begin
        ASQLDBHelper.Query.First;
        if ASQLDBHelper.Query.Eof then
        begin
          //不存在此手机号
          ADesc:=('旧手机号未注册');
          Exit;
        end
        else
        begin
          //旧密码不正确
          if ASQLDBHelper.Query.FieldByName('password').AsString<>AOldPassword then
          begin
            ADesc:=('旧密码不正确');
            Exit;
          end;
        end;
    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;


    //判断新手机号是否已经被注册
    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                              +' WHERE appid=:appid '
                              +' and user_type=:user_type'
                              +' and phone=:phone',
                              ['appid',
                              'user_type',
                              'phone'],
                              [AAppID,
                              AUserType,
                              ANewPhone],
                              asoOpen) then
    begin
        ASQLDBHelper.Query.First;
        if ASQLDBHelper.Query.Eof then
        begin
            //不存在此手机号
            //表示此手机号没有注册过
        end
        else
        begin
          //此手机号已经被注册
          ADesc:=('新手机号已经被注册');
          Exit;
        end;
    end
    else
    begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
    end;

    //不能频繁发送验证码
    //一分钟之内只能发送一次
    //查询出上次发送注册验证码的时间
    AHttpResponse:=SimpleCallAPI(GlobalServiceProject.SendCaptchaRestUrl,
                    nil,
                    '',
                    ['appid',
                    'user_type',
                    'account',
                    'captcha_type'],
                    [AAppID,
                    AUserType,
                    ANewPhone,
                    Const_CaptchaType_ChangePhoneNum
                    ],
                      GlobalServiceProject.GetAppSignType(AAppID),
                      GlobalServiceProject.GetAppSecret(AAppID)
                    );
    AHttpResponseJson:=TSuperObject.Create(AHttpResponse);

    if AHttpResponseJson.I['Code']=SUCC then
    begin
      ADesc:=('验证码发送成功');
      ACode:=SUCC;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:=('验证码发送失败 '+AHttpResponseJson.S['Desc']);
      Exit;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

