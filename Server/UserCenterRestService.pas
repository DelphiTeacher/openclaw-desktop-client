function TsrvUserCenterRestService.GetUserLevelPower(const AAppID:String;const  AUserFID: String;
  const AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

    ADataJson:=TSuperObject.Create();

    //查询用户当前等级和升级所需经验
    if not ASQLDBHelper.SelfQuery( ' SELECT A.name,A.fid,IFNULL(A.level,0) AS level,IFNULL(A.exp,0) AS exp, '
                                  +' B.level AS next_level,B.name AS level_name,B.upgrade_need_exp_increment '
                                  +' FROM '+UserCenterServiceModule.DBModule.DBConfig.GetTablePrefix+'tbluser A LEFT JOIN '+UserCenterServiceModule.DBModule.DBConfig.GetTablePrefix+'tbluser_level_exp_setting B '
                                  +' ON A.appid = B.appid AND IFNULL(A.level,0) < B.level '
                                  +' WHERE A.appid =:appid AND A.fid =:user_fid LIMIT 0,1 ',
                                  ['appid','user_fid'
                                  ],
                                  [
                                  AAppID,AUserFID
                                  ],
                                  asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;
    ADataJson.O['UserLevelInfo']:=JSonFromRecord(ASQLDBHelper.Query);

    //查询用户等级权限
    if not ASQLDBHelper.SelfQuery(' SELECT A.*, '
                                    //是否已获得
                                    +' (B.level>=A.need_user_level) AS is_getted '
                                    +' FROM tblpower A '
                                    +' LEFT JOIN tbluser B ON A.appid=B.appid AND B.fid=:user_fid '
                                    +' WHERE A.appid=:appid '
                                    +' ORDER BY A.need_user_level ASC ',
                                    ['appid','user_fid'
                                    ],
                                    [
                                    AAppID,AUserFID
                                    ],
                                    asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    //成功
    ADesc:=('查询用户等级权限成功');
    ACode:=SUCC;
    JSonFromDataSetTo(ASQLDBHelper.Query,'RecordList',ADataJson);

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

