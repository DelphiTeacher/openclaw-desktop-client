function TsrvUserCenterRestService.SetAllNoticeReaded(const AAppID:String;const
  AUserFID: String; const AKey, ANoticeClassify,
  ARemoteLocation: String): String;
var
  ACode,I:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  ANoticeFIDsList:TStringList;
var
  APushFID:Integer;
  ASQLDBHelper:TBaseDBHelper;

  AWhere:String;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;



  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

//  if Trim(ANoticeClassify)='' then
//  begin
//    ADesc:=('ANoticeClassify不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  try

    ANoticeFIDsList:=TStringList.Create;


    AWhere:='';
    if ANoticeClassify<>'' then
    begin
      AWhere:=' and A.notice_classify='+QuotedStr(ANoticeClassify)+' ';
    end;


    if ASQLDBHelper.SelfQuery('SELECT fid FROM tbluser_notice '
                              +' WHERE appid=:appid '
                              +' and (user_fid=:user_fid OR user_fid=0) '
                              //+' and notice_classify=:notice_classify'
                              +AWhere
                              +' and IFNULL(is_deleted,0)=0',
                              ['appid','user_fid'//,'notice_classify'
                              ],
                              [AAppID,AUserFID//,ANoticeClassify
                              ],
                              asoOpen) then
    begin
      if ASQLDBHelper.Query.FindFirst then
      begin
        ANoticeFIDsList.Add(ASQLDBHelper.Query.FieldByName('fid').AsString);
        While ASQLDBHelper.Query.FindNext do
        begin
          ANoticeFIDsList.Add(ASQLDBHelper.Query.FieldByName('fid').AsString);
        end;
      end;
    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    for I := 0 to ANoticeFIDsList.Count-1 do
    begin
      //判断是否存在记录
      if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_notice_read_state '
                              +' WHERE appid=:appid '
                              +' and user_fid=:user_fid and notice_fid=:notice_fid',
                              ['appid','user_fid','notice_fid'],
                              [AAppID,AUserFID,StrToInt(ANoticeFIDsList[I])],
                              asoOpen) then
      begin
        if Not ASQLDBHelper.Query.Eof then
        begin
          //存在记录
        end
        else
        begin
          //不存在
          //消息设置为已读
          if ASQLDBHelper.SelfQuery('INSERT INTO tbluser_notice_read_state '
                                  +' (appid,user_fid,notice_fid,createtime,is_readed) '
                                  +' VALUES '
                                  +' (:appid,:user_fid,:notice_fid,:createtime,:is_readed) ',
                                  ['appid',
                                  'user_fid',
                                  'notice_fid',
                                  'createtime',
                                  'is_readed'],
                                  [
                                  AAppID,
                                  AUserFID,
                                  StrToInt(ANoticeFIDsList[I]),
                                  Now,
                                  1
                                  ],
                                  asoExec) then
          begin
            //消息设置成功

          end
          else
          begin
            //数据库连接失败或异常
            ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
            Exit;
          end;

        end;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end

    end;

    if ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_notice_read_state '
                              +' WHERE appid=:appid '
                              +' and user_fid=:user_fid and notice_fid=:notice_fid'
                              +' and is_readed=1',
                              ['appid','user_fid','notice_fid'],
                              [AAppID,AUserFID,StrToInt(ANoticeFIDsList[ANoticeFIDsList.Count-1])],
                              asoOpen) then
    begin

      if Not ASQLDBHelper.Query.Eof then
      begin
        //消息设置成功
        ADesc:=('消息设置成功');
        ACode:=SUCC;
      end
      else
      begin
        //失败
        ADesc:=('消息设置失败');
        Exit;
      end;

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'SetAllNoticeReaded');

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

function TsrvUserCenterRestService.SetUserRecvAddrIsDefault(const AAppID:String;const
  AUserFID: String; const AKey: String; const AUserRecvAddrFID: Integer;
  const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('UserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if AUserRecvAddrFID=0 then
  begin
    ADesc:=('UserRecvAddrFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;




  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //检查是否是合法的用户
    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin

      Exit;
    end;


    //修改用户的收货地址为默认
    if ASQLDBHelper.SelfQuery('UPDATE tbluser_recv_addr '
                              +' SET '
                              +' is_default=1 '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              ['appid',
                              'fid'],
                              [
                              AAppID,
                              AUserRecvAddrFID
                              ],
                              asoExec) then
    begin

        //将用户其他的收货地址修改为不默认
        if ASQLDBHelper.SelfQuery('UPDATE tbluser_recv_addr '
                                  +' SET '
                                  +' is_default=0 '
                                  +' WHERE appid=:appid '
                                  +' and user_fid=:user_fid '
                                  +' and fid<>:fid ',
                                  ['appid',
                                  'user_fid',
                                  'fid'],
                                  [
                                  AAppID,
                                  AUserFID,
                                  AUserRecvAddrFID
                                  ],
                                  asoExec) then
        begin

            //成功
            ADesc:=('用户收货地址设置默认成功');
            ACode:=SUCC;

        end
        else
        begin
            //数据库连接失败或异常
            ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        end;

    end
    else
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
    end;



  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

function TsrvUserCenterRestService.set_role_power(const AAppID: String;
  const AUserFID: String; const AKey, role_fid,
  ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ADataJson2:ISuperObject;

  ASQLDBHelper:TBaseDBHelper;

//  ABillCode:String;

  AIntfItem:TCommonRestIntfItem;
  AParamJsonArray:ISuperArray;
//  ARecordDataJson:ISuperObject;
//
//  AHttpResponse:String;
//  AHttpResponseJson:ISuperObject;
//  I: Integer;
  AStringStream:TStringStream;
  I: Integer;
  ASuperObject:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

//  if AUserFID=0 then
//  begin
//    ADesc:=('UserFID不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

//  if ANavigationFID<0 then
//  begin
//    ADesc:=('NavigationFID不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  if AUserFID='' then
  begin
    ADesc:=('AUserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

//  if Trim(bill_no)='' then
//  begin
//    ADesc:=('bill_no不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

//  if Trim(process)='' then
//  begin
//    ADesc:=('process不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;



  AStringStream:=TStringStream.Create('',TEncoding.UTF8);
  try
    AStringStream.LoadFromStream(RequestStream);
    try
      AParamJsonArray:=TSuperArray.Create(AStringStream.DataString);


//      if AParamJsonArray.Length=0 then
//      begin
//        ADesc:=('单据列表不能为空');
//        Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//        Exit;
//      end;

    except
      on E:Exception do
      begin
        ADesc:=('RequestStream不是合法的JsonArray格式');
        Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
        Exit;
      end;
    end;
  finally
    FreeAndNil(AStringStream);
  end;




  if Not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try
      //先查询出这个角色的原权限列表
      AIntfItem:=CommonRestServiceModule.IntfList.Find('role_power');
      if AIntfItem=nil then
      begin
        ADesc:='不存在role_power接口';
        Exit;
      end;
      if not AIntfItem.GetRecordList(UserCenterServiceModule.DBModule,
                                    ASQLDBHelper,
                                    '',
                                    1,
                                    MaxInt,
                                    ConvertJsonArray(GetWhereCondition('AND','role_fid','=',role_fid)).AsJson,
                                    '',
                                    '',0,0,'',0,
                                    ACode,
                                    ADesc,
                                    ADataJson2,
                                    nil
                                    ) then
      begin
        Exit;
      end;

      //role_fid,power_fid,value(0表示不允许,1表示允许)
      for I := 0 to AParamJsonArray.Length-1 do
      begin
        ASuperObject:=LocateJsonArray(ADataJson2.A['RecordList'],
                                      ['role_fid','power_fid'],
                                      [role_fid,AParamJsonArray.O[I].S['power_fid']]
                                      );
        if ASuperObject=nil then
        begin
          //新增
          AIntfItem.AddRecord(AIntfItem.DBModule,
                              ASQLDBHelper,
                              AAppID,
                              AParamJsonArray.O[I],
                              nil,
                              ACode,
                              ADesc,
                              ADataJson
                              );
        end
        else
        begin
          //修改
          AIntfItem.UpdateRecord(AIntfItem.DBModule,
                                ASQLDBHelper,
                                AAppID,
                                AParamJsonArray.O[I],
                                ConvertJsonArray(GetWhereCondition('AND','fid','=',ASuperObject.I['fid'])).AsJson,
                                '',
                                ACode,
                                ADesc,
                                ADataJson
                                );
        end;
        
      end;



      ACode:=SUCC;
      ADesc:=('角色权限设置成功!');



  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;



end;

function TsrvUserCenterRestService.sync_user_chatgpt_use_status(const AKey,
