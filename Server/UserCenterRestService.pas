function TsrvUserCenterRestService.UnBindPhoneNum(const AAppID:String;const
  AUserFID: String; const AKey, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
var
  AHttpResponse:String;
  AHttpResponseJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //检查是否是合法的用户
    if IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin
      //解除手机号码
      if ASQLDBHelper.SelfQuery(' UPDATE tbluser '
                                + 'SET phone='''' '
                                +' WHERE fid=:fid and appid=:appid',
                                ['fid',
                                'appid'],
                                [AUserFID,
                                AAppID],
                                asoExec
                                ) then
      begin
        ADesc:=('解除手机号码绑定成功');
        ACode:=SUCC;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;


end;

function TsrvUserCenterRestService.UnBindThirdpartyAccount(const AAppID:String;const
  AUserFID: String; const AKey, AAccountType, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc,ASql:String;
  ADataJson:ISuperObject;
  ASQLDBHelper:TBaseDBHelper;
//var
//  AHttpResponse:String;
//  AHttpResponseJson:ISuperObject;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(AAccountType)='' then
  begin
    ADesc:=('AAccountType不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //检查是否是合法的用户
    if IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
    begin

      //判断解除绑定的账户是类型
      if Trim(AAccountType)=Const_RegisterLoginType_WeiXin then
      begin
        ASql:=' SET wx_open_id='''', '+'wx_union_id='''' '+'wx_auth_token='''' ';
      end
      else if Trim(AAccountType)=Const_RegisterLoginType_Alipay then
      begin
        ASql:=' SET alipay_open_id='''', '+'alipay_auth_token='''' ';
      end
      else if Trim(AAccountType)=Const_RegisterLoginType_FumaMX then
      begin
        ASql:=' SET fumamx_open_id='''', '+'fumamx_auth_token='''' ';
      end
      else if Trim(AAccountType)=Const_RegisterLoginType_Apple then
      begin
        ASql:=' SET apple_open_id='''', '+'apple_auth_token='''' ';
      end
      else if Trim(AAccountType)=Const_RegisterLoginType_FaceBook then
      begin
        ASql:=' SET fb_open_id='''', '+'fb_auth_token='''' ';
      end
      else if Trim(AAccountType)=Const_RegisterLoginType_Twitter then
      begin
        ASql:=' SET tw_open_id='''', '+'tw_auth_token='''' ';
      end;

      //解除第三方账号
      if ASQLDBHelper.SelfQuery(' UPDATE tbluser '
                                + ASql
                                +' WHERE fid=:fid and appid=:appid',
                                ['fid',
                                'appid'],
                                [AUserFID,
                                AAppID],
                                asoExec
                                ) then
      begin
        ADesc:=('解除账号绑定成功');
        ACode:=SUCC;
      end
      else
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;
    end;
  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

