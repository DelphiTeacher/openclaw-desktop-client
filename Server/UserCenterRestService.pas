//  begin
//    ADesc:=('AUserFID不存在');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try

//    //判断员工账号是否合法
//    if Not IsValidUser(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
//    begin
//      ADesc:=('员工账号不合法');
//      Exit;
//    end;
//
//    //判断用户账号是否存在  可用
//    if Not IsValidUser(ASQLDBHelper,AAppID,AUserFID,ADesc) then
//    begin
//      ADesc:=('用户账号不合法');
//      Exit;
//    end;

    //修改审核信息
    if not ASQLDBHelper.SelfQuery('UPDATE tbluser_suggestions '
                              +' SET audit_user_fid=:audit_user_fid,'
                              +' audit_state=:audit_state,'
                              +' audit_remark=:audit_remark,'
                              +' audit_time=:audit_time '
                              +' WHERE appid=:appid '
                              +' and fid=:fid ',
                              ['audit_user_fid',
                              'audit_state',
                              'audit_remark',
                              'audit_time',
                              'appid',
                              'fid'],
                              [
                              AAuditUserFID,
                              AAuditState,
                              AAuditRemark,
                              Now,
                              AAppID,
                              ASuggestionFID
                              ],
                              asoExec) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;



    //设置审核状态成功
    ADesc:=('审核成功');
    ACode:=SUCC;


    AUserFID:='';
    //如果意见被采纳,赠送积分
    if AAuditState=1 then
    begin
        if not ASQLDBHelper.SelfQuery('SELECT * FROM tbluser_suggestions WHERE fid='+IntToStr(ASuggestionFID)) then
        begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
          Exit;
        end;
        if ASQLDBHelper.Query.Eof then
        begin
          //记录不存在
          Exit;
        end;


        AUserFID:=ASQLDBHelper.Query.FieldByName('user_fid').AsString;
        if AUserFID<>'' then
        begin
          AHttpResponse:=SimpleCallAPI(GlobalServiceProject.ScoreCenterServer+'gift_score',
                                          nil,
                                          '',
                                          ['appid',
                                          'user_fid',
                                          'key',
                                          'rule_type',
                                          'value',
                                          'gift_to_user_fid',
                                          'order_type',
                                          'order_fid'],
                                          [AAppID,
                                          AEmpFID,
                                          '',
                                          Const_RuleType_SuggestionAuditPass,
                                          0,
                                          AUserFID,
                                          Const_RuleType_SuggestionAuditPass,
                                          0],
                                          GlobalServiceProject.GetAppSignType(AAppID),
                                          GlobalServiceProject.GetAppSecret(AAppID)
                                          );
        end;
    end;




    //发送即时消息给客服
    if (GlobalServiceProject.AppList.Find(AAppID)<>nil)
      and (GlobalServiceProject.AppList.Find(AAppID).is_enable_fastmsg=1)
      and (GlobalServiceProject.AppList.Find(AAppID).service_user_fid<>'') then
    begin

        if not UserCenterServiceModule.AnonymousGetUserPublicInfo(ASQLDBHelper,AAppID,GlobalServiceProject.AppList.Find(AAppID).service_user_fid,ADesc,AServiceUserJson) then
        begin
          Exit;
        end;



        AUserJson:=TSuperObject.Create();
        AUserJson.I['fastmsg_user_id']:=1;
        if AUserFID<>'' then
        begin
          if not UserCenterServiceModule.AnonymousGetUserPublicInfo(ASQLDBHelper,AAppID,AUserFID,ADesc,AUserJson) then
          begin
            Exit;
          end;
        end;


        AHttpResponse:=SimpleCallAPI('sendmsg',
                                      nil,
                                      GlobalServiceProject.AppList.Find(AAppID).fastmsg_webapi_url+'webapi/',
                                      ['key',
                                      'ispost',
                                      'timeout',

                                      'sender',
                                      'receiver',
                                      'content'
                                      ],
                                      [GlobalServiceProject.AppList.Find(AAppID).fastmsg_key,
                                      0,
                                      15000,

                                      //发送人
                                      AServiceUserJson.I['fastmsg_user_id'],
                                      //接收人
                                      AUserJson.I['fastmsg_user_id'],
                                      //内容
                                      '您的意见已处理:'+AAuditRemark
                                      ],
                                      '',
                                      ''
                                      );

    end;




  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;



