function TsrvUserCenterRestService.GetUserList(const AAppID:String;const  AEmpFID: String;
  const AKey,
  AFilterUserAccount,
  AFilterUserType,
  AFilterCertAuditState,
//  AFilterPhone,
  AFilterFastmsgUserAccount: String;
//  const AFilterUserName: String;
  const APageIndex,
  APageSize: Integer; const ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;
var
  AUserAccountCondition:String;
  AUserTypeCondition:String;
  ACertAuditStateCondition:String;

  AFastmsgUserId:Integer;
  AFastmsgUserIdCondition:String;

  ASQLDBHelper:TBaseDBHelper;
begin


  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

//  //商家接单时通知骑手  获取所有骑手列表时没有员工FID  所以传0
//  if (Trim(AEmpFID)='') or (Trim(AEmpFID)='0') then
//  begin
//    ADesc:=('EmpFID不能为空');
//    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
//    Exit;
//  end;

  if APageIndex<1 then
  begin
    ADesc:=('PageIndex不能小于1');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if APageSize<1 then
  begin
    ADesc:=('PageSize不能小于1');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;



  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


//    if (Trim(AEmpFID)<>'') and (Trim(AEmpFID)<>'0') then
//    begin
//      //检查是否是合法的用户
//      if Not IsValidUser(ASQLDBHelper,AAppID,AEmpFID,ADesc) then
//      begin
//
//        Exit;
//      end;
//    end;

    AUserAccountCondition:='';
    if AFilterUserAccount<>'' then
    begin
      AUserAccountCondition:=' and (name='+QuotedStr(AFilterUserAccount)
                            +' or email='+QuotedStr(AFilterUserAccount)
                            +' or phone='+QuotedStr(AFilterUserAccount)+') ';
    end;

    AUserTypeCondition:='';
    if AFilterUserType<>'' then
    begin
      AUserTypeCondition:=' and user_type='+AFilterUserType+' ';
    end;

    ACertAuditStateCondition:='';
    if AFilterCertAuditState<>'' then
    begin
      ACertAuditStateCondition:=' and IFNULL(cert_audit_state,0)='+AFilterCertAuditState+' ';
    end;

    AFastmsgUserId:=0;
    AFastmsgUserIdCondition:='';
    if AFilterFastmsgUserAccount<>'' then
    begin
      if TryStrToInt(AFilterFastmsgUserAccount,AFastmsgUserId) then
      begin
        //是聊天账号
        AFastmsgUserIdCondition:=' and IFNULL(fastmsg_user_id,0)='+AFilterFastmsgUserAccount+' ';

      end
      else
      begin
        //可能是手机号或者用户名
        AFastmsgUserIdCondition:=' and (name='+QuotedStr(AFilterFastmsgUserAccount)
                              +' or email='+QuotedStr(AFilterFastmsgUserAccount)
                              +' or phone='+QuotedStr(AFilterFastmsgUserAccount)+') ';
      end;
      
    end;

    //查询用户列表
    if not ASQLDBHelper.SelfQuery(' Select * from tbluser '
                                  +' WHERE appid=:appid '
                                  +' and IFNULL(is_deleted,0)=0 '
                                  +AUserAccountCondition
                                  +AUserTypeCondition
                                  +ACertAuditStateCondition
                                  +AFastmsgUserIdCondition
                                  +' ORDER BY createtime DESC '
                                  +' LIMIT :pageindex,:pagesize ',
                                  ['appid',
                                  'pageindex',
                                  'pagesize'],
                                  [
                                  AAppID,
                                  (APageIndex-1)*APageSize,
                                  APageSize
                                  ],
                                  asoOpen) then
    begin
      //数据库连接失败或异常
      ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
      Exit;
    end;

    //成功
    ADesc:=('查询用户列表成功');
    ACode:=SUCC;
    ADataJson:=JSonFromDataSet(ASQLDBHelper.Query,'UserList');

    //查询用户总数
    if ASQLDBHelper.SelfQuery(' Select count(*) as Counts from tbluser '
                          +' WHERE appid=:appid '
                          +' and IFNULL(is_deleted,0)=0 '
                          +AUserAccountCondition
                          +AUserTypeCondition
                          +ACertAuditStateCondition
                          +AFastmsgUserIdCondition,
                          ['appid'],
                          [AAppID],
                          asoOpen) then
    begin
      ADataJson.I['Counts']:=ASQLDBHelper.Query.FieldByName('Counts').AsInteger;
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

