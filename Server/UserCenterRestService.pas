function TUserOrderGoodsUseStatus.CanUseRights(ARights: String;var ADesc:String): Boolean;
begin
  Result:=False;

  if not Self.CanUse(ADesc) then
  begin
//    ADesc:=('授权失效');
    Exit;
  end;

  if Self.VIPRights=nil then
  begin
    Self.LoadLicense;
  end;
  if Self.VIPRightsUsage=nil then
  begin
    Self.LoadUsage;
  end;
  if VIPRights=nil then
  begin
    ADesc:='权益为空';
    Exit;
  end;
  if VIPRightsUsage=nil then
  begin
    ADesc:='权益使用量为空';
    Exit;
  end;

  if not VIPRights.Contains(ARights) then
  begin
    ADesc:='不存在'+ARights+'权益';
    Exit;
  end;

  //-1表示不限制
  if VIPRights.I[ARights]=-1 then
  begin
    Result:=True;
    Exit;
  end;

  if VIPRightsUsage.I[ARights]>=VIPRights.I[ARights] then
  begin
    ADesc:=ARights+'权益已用完';
    Exit;
  end;

  Result:=True;
  
end;

procedure TUserOrderGoodsUseStatus.CheckNewDay;
begin
  if LastNewDayDate<>StdDateToStr(Now()) then
  begin
    //如果有每天的免费使用次数,看看有没有超
    TodayUsedTrialServiceCount:=0;
    TodayUsedServiceCount:=0;

    LastNewDayDate:=StdDateToStr(Now());
  end;
end;

function TUserOrderGoodsUseStatus.Used: Boolean;
var
  I: Integer;
  AOrderGoods:ISuperObject;
  ARecordDataJson:ISuperObject;
begin
  Result:=False;

  //如果有每天的免费使用次数,看看有没有超
  if SumTrialServiceCountPerDay>0 then
  begin
    if TodayUsedTrialServiceCount<SumTrialServiceCountPerDay then
    begin
      TodayUsedTrialServiceCount:=TodayUsedTrialServiceCount+1;
      TodayUsedServiceCount:=TodayUsedServiceCount+1;
      Exit;
    end;
  end;



  if IsTempUser then
  begin
    //匿名临时用户每天次数用完了
    Result:=False;
    Exit;
  end;

  //如果买了很多套,那么其实只要改一个地方就行了
  for I := 0 to OrderGoodsArray.Length-1 do
  begin
    AOrderGoods:=OrderGoodsArray.O[I];
    if AOrderGoods.I['used_service_count']<AOrderGoods.I['service_count'] then
    begin
      AOrderGoods.I['used_service_count']:=AOrderGoods.I['used_service_count']+1;
      Self.SumUsedServiceCount:=SumUsedServiceCount+1;
      TodayUsedServiceCount:=TodayUsedServiceCount+1;

      //提交到数据库更新队列中
      ARecordDataJson:=SO();
      ARecordDataJson.I['used_service_count']:=AOrderGoods.I['used_service_count'];
      GlobalCommonRestIntf_ASyncCallTaskManager.UpdateRecord('order_goods',AppID,ARecordDataJson,GetWhereKeyJson(['fid'],[AOrderGoods.I['fid']]));

      Exit;
    end;
  end;

end;

procedure TUserOrderGoodsUseStatus.UseRights(ARights: String; AInc: Integer);
begin
  if VIPRightsUsage<>nil then
  begin
    VIPRightsUsage.I[ARights]:=VIPRightsUsage.I[ARights]+AInc;
  end;
end;

constructor TUserOrderGoodsUseStatusList.Create(
  const AObjectOwnership: TObjectOwnership;
  const AIsCreateObjectChangeManager: Boolean);
begin
  inherited;

  FGetUserGoodsLicenseLoader:=TSkinObjectChangeManager.Create(Self);
  FGetUserGoodsUsageLoader:=TSkinObjectChangeManager.Create(Self);

end;

destructor TUserOrderGoodsUseStatusList.Destroy;
begin
  FreeAndNil(FGetUserGoodsLicenseLoader);
  FreeAndNil(FGetUserGoodsUsageLoader);
  inherited;
end;

function TUserOrderGoodsUseStatusList.Find(AAppID, AUserFID,
  AShopGoodsName: String): TUserOrderGoodsUseStatus;
var
  I: Integer;
begin
  Result:=nil;
  for I := 0 to Self.Count-1 do
  begin
    if (Items[I].AppID=AAppID)
      and (Items[I].UserFID=AUserFID)
      and (Items[I].ShopGoodsName=AShopGoodsName) then
    begin
      Result:=Items[I];
      Break;
    end;
  end;
end;

function TUserOrderGoodsUseStatusList.GetItem(
  Index: Integer): TUserOrderGoodsUseStatus;
begin
  Result:=TUserOrderGoodsUseStatus(Inherited Items[Index]);
end;

function TUserOrderGoodsUseStatusList.GetStatus(AAppID, AUserFID,
  AShopGoodsName: String;AIsTempUser:Boolean): TUserOrderGoodsUseStatus;
var
  I: Integer;
begin
  Result:=Find(AAppID, AUserFID, AShopGoodsName);
  if Result=nil then
  begin
    //判断有没有获取授权的方法列表,有的话就调用
    if FGetUserGoodsLicenseLoader.LinkCount>0 then
    begin
      Result:=TUserOrderGoodsUseStatus.Create(Self);
      Result.AppID:=AAppID;
      Result.UserFID:=AUserFID;
      Result.ShopGoodsName:=AShopGoodsName;
      Result.IsTempUser:=AIsTempUser;
      Result.LoadLicense;
      Result.LoadUsage;
//      FGetUserGoodsLicenseLoader.DoChange(Result);
      Self.Add(Result);
    end;
  end;

end;

