procedure TsrvUserCenterRestService.logout_by_key(AKey: String);
var
  ADesc:String;
var
  AUserAccessToken:TUserAccessToken;
  ASQLDBHelper:TBaseDBHelper;
begin

  ADesc:='';
  AUserAccessToken:=nil;

  AUserAccessToken:=GlobalServiceProject.FUserAccessTokenList.Find(AKey);
  if AUserAccessToken=nil then
  begin
    Exit;
  end;

  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Exit;
  end;
  try

      //生成一个key  返回给客户端  保存到User表中
      if not ASQLDBHelper.SelfQuery('UPDATE tbluser '
                                  +' SET login_key='''' '
                                  +' WHERE login_key=:login_key ',
                                  ['login_key'],
                                  [AKey],
                                  asoExec) then
      begin
        //数据库连接失败或异常
        ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
        Exit;
      end;


      //防止报错,Remove改成Clear
//      GlobalServiceProject.FUserAccessTokenList.Remove(AUserAccessToken);
      AUserAccessToken.Clear;

      //将原token标记为空
      if not ASQLDBHelper.SelfQuery('UPDATE tbluser_access_token '
                                  +' SET access_token='''' '
                                  +' WHERE access_token=:access_token ',
                                  ['access_token'],
                                  [AKey],
                                  asoExec) then
      begin
      end;


  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
  end;

end;

