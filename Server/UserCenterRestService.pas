{ TSyncUserToFastmsgUserThread }

procedure TSyncUserToFastmsgUserThread.Execute;
var
  ACode:Integer;
  ADesc:String;
  AQuery2:TDataset;
  ASQLDBHelper:TBaseDBHelper;
  AStockSettingJson:ISuperObject;
  AFastMsgUserId:Integer;
  AApp:TOpenplatformApp;
  AAppID:String;
  AUserFID:String;
  AHttpResponse:String;
begin
      if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
      begin
          Exit;
      end;
      try
            Sleep(10*1000);

            AQuery2:=ASQLDBHelper.NewTempQuery;
            try
                //查询没有fastmsg_user_id的用户
                if ASQLDBHelper.SelfQuery(
                          ' SELECT * FROM tbluser WHERE IFNULL(fastmsg_user_id,0)=0 ORDER BY createtime ASC',
                           [],[],asoOpen,False,AQuery2) then
                begin

                    while (not AQuery2.Eof) and (Not Self.Terminated) do
                    begin

                          AAppID:=IntToStr(AQuery2.FieldByName('appid').AsInteger);
                          AUserFID:=AQuery2.FieldByName('fid').AsString;
                          AFastMsgUserId:=0;

                          //如果App启用了IM的功能,那么新建FastMsg用户,规则8位,
                          AApp:=GlobalServiceProject.AppList.Find(AAppID);
                          if AApp<>nil then
                          begin
                              if (AApp.is_enable_fastmsg=1) then
                              begin
                                  AFastMsgUserId:=GetMaxFID(ASQLDBHelper,'tbluser','fastmsg_user_id',True);
                                  if (AApp.fastmsg_webapi_url<>'') and (AApp.fastmsg_key<>'') then
                                  begin
                                      try
                                                      //#$FEFF'<?xml version="1.0" encoding="utf-8"?>'#$D#$A'<response>'#$D#$A'  <errorcode>0</errorcode>'#$D#$A'</response>'#$D#$A
                                                      AHttpResponse:=SimpleCallAPI('adduser',
                                                                    nil,
                                                                    AApp.fastmsg_webapi_url+'webapi/',
                                                                    ['key',
                                                                    'ispost',
                                                                    'timeout',

                                                                    'workgroupid',
                                                                    'userid',
                                                                    'username',
                                                                    'usertype',
                                                                    'userrole',
                                                                    'userlevel',
                                                                    'nickname',
                                                                    'gender',
                                                                    'departid',
                                                                    'password',
                                                                    'canfound'
                                                                    ],
                                                                    [AApp.fastmsg_key,
                                                                    0,
                                                                    15000,

                                                                    //workgroupid
                                                                    0,
                                                                    //userid
                                                                    AFastMsgUserId,
                                                                    //开放平台的user_fid做为IM的登录名
                                                                    AFastMsgUserId,//AUserFID,
                                                                    0,
                                                                    0,
                                                                    //userlevel
                                                                    AAppID,
                                                                    //nickname
                                                                    AFastMsgUserId,0,0,
                                                                    //password
                                                                    '123456',
                                                                    1
                                                                    ],
                                                                    '',
                                                                    ''
                                                                    );
                                                         ASQLDBHelper.SelfQuery('UPDATE tbluser set fastmsg_user_id=:fastmsg_user_id where fid=:fid',
                                                            ['fastmsg_user_id','fid'],
                                                            [AFastmsgUserId,AUserFID],
                                                            asoExec
                                                            );


                                      finally

                                      end;
                                  end
                                  ;
                              end;
                          end;



                          AQuery2.Next;
                    end;
                end
                else
                begin
                  //数据库连接失败或异常
                  ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
                  uBaseLog.HandleException(nil,'TShopCenterCheckOrderPayStateThread.Execute '+ADesc);
                end;



//                //查询没有fastmsg_user_id的用户
//                if ASQLDBHelper.SelfQuery(
//                          ' SELECT * FROM tbluser WHERE IFNULL(fastmsg_user_id,0)<>0 ORDER BY createtime ASC',
//                           [],[],asoOpen,False,AQuery2) then
//                begin
//
//                    while (not AQuery2.Eof) and (Not Self.Terminated) do
//                    begin
//
//
//                        AHttpResponse:=SimpleCallAPI('addgroupmember',
//                                      nil,
//                                      AApp.fastmsg_webapi_url+'webapi/',
//                                      ['key',
//                                      'ispost',
//                                      'timeout',
//
//                                      'groupid',
//                                      'members'
//                                      ],
//                                      [AApp.fastmsg_key,
//                                      0,
