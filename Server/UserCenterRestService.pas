//
//        ABindKey:=['appid','fid','tw_open_id','tw_auth_token'];
//        ABindValue:=[AAppID,AUserFID,ATwOpenID,ATwAuthToken];
      end;




      if not ASQLDBHelper.SelfQuery('SELECT * FROM tbluser '
                                    +' WHERE appid=:appid '
                                    + ABindType
