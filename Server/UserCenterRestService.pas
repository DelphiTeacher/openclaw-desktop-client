begin
  Result:=False;

  //判断有没有获取授权的方法列表,有的话就调用
  if Owner.FGetUserGoodsLicenseLoader.LinkCount>0 then
  begin
    Owner.FGetUserGoodsLicenseLoader.DoChange(Self);
    Result:=True;
  end;

end;

function TUserOrderGoodsUseStatus.LoadUsage: Boolean;
begin
  Result:=False;
  if VIPRightsUsage=nil then
  begin
    if Owner.FGetUserGoodsUsageLoader.LinkCount>0 then
    begin
      //不同的商品,不同的加载方式
      Owner.FGetUserGoodsUsageLoader.DoChange(Self,Self.ShopGoodsName);
      Result:=True;
    end;
  end;

end;

