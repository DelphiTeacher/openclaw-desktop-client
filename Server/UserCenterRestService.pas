function TsrvUserCenterRestService.DelUserNotice(const AAppID:String;const
  AUserFID: String; const AKey, ANoticeFids, ARemoteLocation: String): String;
var
  ACode:Integer;
  ADesc:String;
  ADataJson:ISuperObject;

  ANoticeStringList:TStringList;
  ASQLDBHelper:TBaseDBHelper;
  I,temp: Integer;
begin

  ACode:=FAIL;
  ADesc:='';
  ADataJson:=nil;


  if (AAppID='') or (StrToIntDef(AAppID,0)=0) then
  begin
    ADesc:=('AppID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if (Trim(AUserFID)='') or (Trim(AUserFID)='0') then
  begin
    ADesc:=('AUserFID不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;

  if Trim(ANoticeFids)='' then
  begin
    ADesc:=('ANoticeFids不能为空');
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;


  if not UserCenterServiceModule.DBModule.GetDBHelperFromPool(ASQLDBHelper,ADesc) then
  begin
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
    Exit;
  end;
  try


    //批量删除通知
    ANoticeStringList:=TStringList.Create;
    try
      temp:=0;
      ANoticeStringList.CommaText:=ANoticeFids;
      for I := 0 to ANoticeStringList.Count-1 do
      begin
        if ASQLDBHelper.SelfQuery('UPDATE tbluser_notice'
                              +' SET is_deleted=1 '
                              +' WHERE appid=:appid '
                              +' and fid=:fid and (user_fid=:user_fid OR user_fid=0)',
                              ['appid','fid','user_fid'],
                              [AAppID,ANoticeStringList[I],AUserFID],
                              asoExec) then
        begin
          temp:=temp+1;
        end
        else
        begin
          //数据库连接失败或异常
          ADesc:='数据库连接失败或异常'+' '+ASQLDBHelper.LastExceptMessage;
          Exit;
        end;
      end;

      if temp=ANoticeStringList.Count then
      begin
        //成功
        ACode:=SUCC;
        ADesc:=('删除成功');
        Exit;
      end
      else
      begin
        //失败
        ACode:=FAIL;
        ADesc:=('删除失败');
        Exit;
      end;

    finally
      FreeAndNil(ANoticeStringList);
    end;

  finally
    UserCenterServiceModule.DBModule.FreeDBHelperToPool(ASQLDBHelper);
    Result:=ReturnJson(ACode,ADesc,ADataJson).AsJSON;
  end;

end;

