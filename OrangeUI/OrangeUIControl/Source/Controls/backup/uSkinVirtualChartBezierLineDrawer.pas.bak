//      //生成圈的Path
//      APathActionItem:=TPathActionItem(ADataItem.FDrawPathActions.Add);
//      APathActionItem.ActionType:=patAddEllipse;
//      APathActionItem.X:=ADrawData.FLinePoint.X-ASkinVirtualChartDefaultMaterial.LineDotRadius;
//      //这个柱状图是从底部上来的
//      APathActionItem.Y:=ADrawData.FLinePoint.Y-ASkinVirtualChartDefaultMaterial.LineDotRadius;
//      APathActionItem.X1:=ADrawData.FLinePoint.X+ASkinVirtualChartDefaultMaterial.LineDotRadius;
//      APathActionItem.Y1:=ADrawData.FLinePoint.Y+ASkinVirtualChartDefaultMaterial.LineDotRadius;
